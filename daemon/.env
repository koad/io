KOAD_IO_ENTITY=astro
KOAD_IO_PORT=28282
KOAD_IO_TYPE=daemon
KOAD_IO_APP_NAME="koad:io daemon"

# MONGO_URL=false is a GUARDRAIL — it is intentional, not a bug.
# The daemon runs on in-memory Mongo collections only. Every collection
# must be declared via koad.mongo (see ~/.koad-io/packages/core), which
# wires the connection through `{ connection: null }` so data stays in
# memory. If you're seeing a MongoParseError for "false" at boot, it
# means some code tried to use a regular Mongo.Collection without going
# through koad.mongo. Fix the offender — don't disable the guardrail.
MONGO_URL=false

KOAD_IO_DOMAIN=10.10.10.10:28282

# The daemon is the live evolution space — never built. It runs in dev mode
# (meteor command, hot reload, meteor shell available) so the kingdom can
# iterate against it in real time. Keeping KOAD_IO_LOCAL=true here makes
# sure `koad-io start` always picks the dev path, whatever the caller did.
KOAD_IO_LOCAL=true

# Package dirs — include forge packages so the daemon can resolve
# business-layer packages like koad:io-ddp-shell.
METEOR_PACKAGE_DIRS=$HOME/.forge/packages:$HOME/.ecoincore/packages:$HOME/.koad-io/packages

#KOAD_IO_ENTITY_SCANNER=true
KOAD_IO_ENTITY_SCANNER_LIST=aegis,alice,argus,astro,cacula,chiron,copia,faber,iris,janus,juno,livy,lyra,mercury,muse,rooty,rufus,salus,sibyl,veritas,vesta,vulcan

# Workers — disabled in the daemon by design. Indexers run one-shot only.
# Control-tower (28283) runs the worker fleet. The daemon (28282) indexes
# on startup and on entity changes via filewatch — no periodic workers.
KOAD_IO_WORKERS_ENABLED=false
KOAD_IO_REQUIRES_DISPLAY=true

# --- Indexers: entity truth (disk-scanned) ---
KOAD_IO_INDEX_PASSENGERS=true
KOAD_IO_INDEX_BONDS=true
KOAD_IO_INDEX_KINGDOMS=true
KOAD_IO_INDEX_KEYS=true
KOAD_IO_INDEX_ENV=true
KOAD_IO_INDEX_ALERTS=true
