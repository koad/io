{
	
	"version": "0.81.1849",
	"manifest_version": 3,
	"name": "koad:io-dark-passenger",
	"description": "koad:io browser extention allows you to navigate away from the kingdom but with your entities as passengers!",
	"homepage_url": "https://github.com/koad/io",

	"icons": {
		"16": "icons/logo-16x.png",
		"48": "icons/logo-48x.png",
		"128": "icons/logo-128x.png",
		"256": "icons/logo-256x.png",
		"512": "icons/logo-512x.png"
	},
	"action": {
		"default_icon": {
			"16": "icons/logo-16x.png",
			"48": "icons/logo-48x.png",
			"128": "icons/logo-128x.png",
			"256": "icons/logo-256x.png",
			"512": "icons/logo-512x.png"
		},
		"default_title": "koad:io"
	},

	"web_accessible_resources": [
		{
			"resources": ["icons/*"],
			"matches": ["<all_urls>"]
		}
	],

	"offline_enabled": true,

	"permissions": [
		"activeTab",
		"declarativeContent",
		"alarms",
		"notifications",
		"storage",
		"bookmarks",
		"clipboardRead",
		"clipboardWrite",
		"contentSettings",
		"history",
		"idle",
		"contextMenus",
		"tabs",
		"geolocation",
		"declarativeNetRequestWithHostAccess",
		"webRequest",
		"webNavigation",
		"management",
		"scripting",
    	"sidePanel",
		"system.memory",
		"system.storage",
		"system.display",
		"system.cpu",
		"windows"
	],
	"host_permissions": [
		"https://youtu.be/*",
		"https://*.youtube.com/*",
		"https://*.youtube-nocookie.com/*",
		"<all_urls>"
	],
	"content_scripts": [
		{
			"matches": ["*://chat.openai.com/*"],
			"js": ["shims/chat.openai.com/copy-conversation-to-clipboard.js"]
		},{
			"description": "Inverts the colours, because its always way too bright!!",
			"matches": ["https://luminocity3d.org/WorldPopDen/*"],
			"js": ["shims/luminocity3d.org/invert-colors.js"]
		},{
			"description": "Appends CPU launch dates to product listings on Dacentec.",
			"matches": ["https://billing.dacentec.com/hostbill/index.php?/cart/dedicated-servers/*"],
			"js": ["shims/dacentec.com/cpu-dater.js"]
		},{
			"matches": [
				"https://youtu.be/*",
				"https://*.youtube.com/*",
				"https://*.youtube-nocookie.com/*"
			],
			"js": ["shims/youtube.com/preview-button.js"],
			"run_at": "document_idle"
		},{
			"matches": ["<all_urls>"],
			"css": ["global/styles.css"],
			"js": ["global/logic.js"]
		}
	],
	"omnibox": { "keyword" : "koad" },

	// provide full screen application
	"options_page": "/index.html",

	// https://developer.chrome.com/docs/extensions/reference/api/sidePanel
	"side_panel": { "default_path": "panel.html" },

	// provide options page as floating popout ontop of extention settings page
	// "options_ui": {"page": "panes/options/index.html", "open_in_tab": false },
	"background": {	
		"service_worker": "background/index.js",
		"type": "module"
	},

	"action": { "default_popup": "panes/popup/index.html" },

	// an extention can only override 1 page
	"chrome_url_overrides" : {
		// "history": "panes/history/index.html"
		// "bookmarks": "panes/bookmarks/index.html"
		// "newtab": "/panes/newtab/index.html"
		"newtab": "/newtab.html"
	},

	// https://developer.chrome.com/docs/extensions/reference/commands/
	// "commands": {
	//	 "run-foo": {
	//		 "suggested_key": {
	//			 "default": "Ctrl+Shift+Y",
	//			 "mac": "Command+Shift+Y"
	//		 },
	//		 "description": "Run \"foo\" on the current page."
	//	 },
	//	 "_execute_action": {
	//		 "suggested_key": {
	//			 "windows": "Ctrl+Shift+Y",
	//			 "mac": "Command+Shift+Y",
	//			 "chromeos": "Ctrl+Shift+Y",
	//			 "linux": "Ctrl+Shift+Y"
	//		 }
	//	 }
	// }

	// "web_accessible_resources": [{
	// 	"resources": ["resources/*"],
	// 	"matches": ["*://www.youtube.com/*"]
	// }],

	// "default_locale": "en",
	// "default_locale": "en_CA",

	"minimum_chrome_version": "116",

	// https://developer.chrome.com/docs/extensions/reference/api/runtime#manifest-externally_connectable
	// Allows the Meteor dev app and production lighthouses to communicate with the
	// service worker directly via chrome.runtime.sendMessage (externally_connectable).
	"externally_connectable": {
		"matches": [
			"http://10.10.10.10:58008/*",
			"https://wonderland.koad.sh/*",
			"https://koad.sh/*"
		]
	}

}
