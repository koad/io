#!/bin/bash

## koad-io cli wrapper
## a component of koad:io
## copyright kingofalldata.com

## The objective of keeping the script human-readable and linear is quite important. It's crucial
## for non-coders to be able to understand what's happening without getting lost in complex structures
## or abstractions.
## 
## Given this approach, this script is designed in a way that logically unfolds the process step by
## step, and each code block corresponds to a specific action or decision. This can make it easier 
## for non-coders to follow along and comprehend.
## 
## While this script might appear a bit verbose due to the repetition, this design choice aligns well
## with our goal of making it clear and readable. This structure is intended to help users understand
## the process and the decision-making logic. Hopefully our approach seems to be a reasonable trade-off
## between readability and conciseness.

# --- Pre-cascade env sanitization ----------------------------------------
#
# Wipe inherited entity-context and koad-io state vars BEFORE the .env
# cascade waterfall runs. Each koad-io invocation must start with a clean
# slate so the cascade is the single source of truth — preventing leakage
# from parent processes (e.g. dispatching Vulcan from inside a Juno
# session that already has KOAD_IO_ROOTED=true and ENTITY_DIR=/home/koad/.juno
# in env, which would otherwise pollute Vulcan's invocation).
#
# Preserved (caller intent, not entity context):
#   ENTITY            — set by the entity launcher (~/.koad-io/bin/<name>)
#                       immediately before exec; the canonical fresh caller intent
#   KOAD_IO_ROOM      — caller-pinned room for room-mode dispatch
#   KOAD_IO_QUIET     — verbosity preference (also set by --quiet flag)
#
# Wiped:
#   ENTITY_*          — entity context (DIR, HOME, HOST, KEYS, DEFAULT_*).
#                       Re-established from the entity .env in the cascade.
#   KOAD_IO_*         — kingdom flags and entity-context flags
#                       (ROOTED, DEFAULT_*, etc). Re-established from
#                       ~/.koad-io/.env and the entity .env in the cascade.
#
# Spec proposal: VESTA-SPEC-NNN — Pre-Cascade Env Sanitization (forthcoming).

_koad_io_room_pin="$KOAD_IO_ROOM"
_koad_io_quiet_pin="$KOAD_IO_QUIET"

# Detect whether we were called from an entity launcher or directly as koad-io.
# Entity launchers set KOAD_IO_VIA_LAUNCHER=1 before calling us.
# If called directly (no launcher), ENTITY is stale env from a parent shell —
# wipe it and all entity context so framework commands run entity-free.
if [[ "$KOAD_IO_VIA_LAUNCHER" != "1" ]]; then
  unset ENTITY
  # Wipe ALL entity and kingdom env vars — clean slate for framework-only cascade
  while IFS= read -r _v; do
    unset "$_v"
  done < <(compgen -v | grep -E '^(KOAD_IO_|ENTITY)' || true)
  # Re-source kingdom-level env only (no entity).
  # ~/.koad-io/.env if it's a directory, or ~/.koad-io itself if it's a file.
  set -a
  if [ -d "$HOME/.koad-io" ]; then
    [ -f "$HOME/.koad-io/.env" ] && source "$HOME/.koad-io/.env"
    [ -f "$HOME/.koad-io/.credentials" ] && source "$HOME/.koad-io/.credentials"
  elif [ -f "$HOME/.koad-io" ]; then
    source "$HOME/.koad-io"
    [ -f "$HOME/.credentials" ] && source "$HOME/.credentials"
  fi
  set +a
else
  unset KOAD_IO_VIA_LAUNCHER
  # Entity launcher path — wipe everything except ENTITY, re-established by cascade
  while IFS= read -r _v; do
    case "$_v" in
      ENTITY) ;;  # set by launcher — preserve
      *)      unset "$_v" ;;
    esac
  done < <(compgen -v | grep -E '^(KOAD_IO_|ENTITY)' || true)
fi

[ -n "$_koad_io_room_pin" ]  && export KOAD_IO_ROOM="$_koad_io_room_pin"
[ -n "$_koad_io_quiet_pin" ] && export KOAD_IO_QUIET="$_koad_io_quiet_pin"
unset _koad_io_room_pin _koad_io_quiet_pin _v

# we want to save CWD as the directory which the command was fired from, and pass this into the regular command.
export CWD=$PWD
[[ $DEBUG ]] && echo "PWD=$PWD";
[[ $DEBUG ]] && echo "ORIG_ARGS=$1 $2 $3 $4 $5 $6 $7 $8 $8"

# Detect --quiet / -q flag or KOAD_IO_QUIET env var.
# Quiet mode suppresses spinners and ANSI decoration while keeping plain-text status output.
# This is intended for AI sessions, scripts, and CI pipelines where animation causes noise.
for _arg in "$@"; do
  if [[ "$_arg" == "--quiet" || "$_arg" == "-q" ]]; then
    export KOAD_IO_QUIET=1
    break
  fi
done
unset _arg

# Strip --quiet / -q from the argument list so subcommands do not see it.
if [[ "$KOAD_IO_QUIET" == "1" ]]; then
  _filtered_args=()
  for _arg in "$@"; do
    [[ "$_arg" == "--quiet" || "$_arg" == "-q" ]] && continue
    _filtered_args+=("$_arg")
  done
  set -- "${_filtered_args[@]}"
  unset _filtered_args _arg
fi

# Separate --flag arguments from positional command arguments.
# Positional args (start, local, dev, etc.) are used for directory-based command
# resolution. Flag args (--local, --attach, --dry-run, etc.) are NOT directory
# names — they pass through to the final command unchanged.
#
# Fix A: preserve --flag value pairs. When a --flag token is followed by a
# token that does not start with --, absorb the next token as the flag's value.
# This keeps --entity juno and --note "some text" paired together rather than
# splitting the value into positionals.
#
# Fix B: _flag_args is kept as a bash array (not flattened to a string) so
# the exec at the bottom can expand it with "${_flag_args[@]}" — preserving
# whitespace inside flag values through to the command's argv.
#
# Backwards compat: KOAD_IO_FLAGS (word-split string) is still exported for
# commands that read it directly (start/stop/restart use it for boolean flags
# like --local and --attach). Boolean flags have no following value token so
# Fix A does not affect them.
_positional_args=()
_flag_args=()
_i=1
while [[ $_i -le $# ]]; do
  _arg="${!_i}"
  if [[ "$_arg" == --*=* ]]; then
    # --key=value form: already self-contained, no lookahead needed
    _flag_args+=("$_arg")
  elif [[ "$_arg" == --* ]]; then
    _next_i=$((_i + 1))
    _next="${!_next_i:-}"
    if [[ -n "$_next" && "$_next" != --* ]]; then
      # Absorb the next token as this flag's value
      _flag_args+=("$_arg" "$_next")
      _i=$((_i + 1))
    else
      # Boolean flag (no value follows, or next token is another flag)
      _flag_args+=("$_arg")
    fi
  else
    _positional_args+=("$_arg")
  fi
  _i=$((_i + 1))
done
set -- "${_positional_args[@]}"
export KOAD_IO_FLAGS="${_flag_args[*]}"
# _flag_args array is kept alive (not unset here) so the exec at the bottom
# of this script can expand it with "${_flag_args[@]}" and preserve whitespace
# in flag values. KOAD_IO_FLAGS (word-split string) is exported for backwards
# compat with commands that read it directly (e.g. start/stop for boolean flags).
unset _positional_args _arg _i _next_i _next

[[ $9 ]] && echo 'You have reached the limits here, sorry -- too many arguments.' && exit 68

# Cascade environments BEFORE hook dispatch — hooks need entity env vars
# (CLAUDE_CONFIG_DIR, GIT_AUTHOR_*, ENTITY_DIR, etc.)
set -a
[ -f "$HOME/.koad-io/.env" ] && source "$HOME/.koad-io/.env"
[ -f "$HOME/.koad-io/.credentials" ] && source "$HOME/.koad-io/.credentials"
if [[ -n "$ENTITY" ]]; then
  ENTITY_LOWER="$(echo "$ENTITY" | tr '[:upper:]' '[:lower:]')"
  [ -f "$HOME/.$ENTITY_LOWER/.env" ] && source "$HOME/.$ENTITY_LOWER/.env"
  [ -f "$HOME/.$ENTITY_LOWER/.credentials" ] && source "$HOME/.$ENTITY_LOWER/.credentials"
fi
set +a

# ensure we have arguments to parse, else run the executed-without-arguments hook.
# waterfall: entity hook > CWD hook > global hook
if [[ $# -eq 0 ]]; then
  HOOK_NAME="executed-without-arguments.sh"
  if   [[ -n "$ENTITY" ]] && [[ -f "$HOME/.$ENTITY/hooks/$HOOK_NAME" ]];  then exec "$HOME/.$ENTITY/hooks/$HOOK_NAME";
  elif [[ -f "$PWD/hooks/$HOOK_NAME" ]];                                   then exec "$PWD/hooks/$HOOK_NAME";
  elif [[ -f "$HOME/.koad-io/hooks/$HOOK_NAME" ]];                         then exec "$HOME/.koad-io/hooks/$HOOK_NAME";
  else echo "no hook found for: $HOOK_NAME" && exit 64;
  fi
fi

# ack — always emit plain-text status so callers can follow progress;
# ANSI decoration is suppressed in quiet mode.
if [[ "$KOAD_IO_QUIET" == "1" ]]; then
  echo "[koad-io] start: $1 (quiet mode)"
else
  echo "--koad-io [$ENTITY] $1 start--"
  echo "$0 [$# arguments]"
  echo "-"
fi
echo "cascading enviroments"
set -a

# Load any global environment details that exist in the koad-io folder.
[ -f $HOME/.koad-io/.env ] && echo "absorbing $HOME/.koad-io/.env" && set -a && source $HOME/.koad-io/.env 
[ -f $HOME/.koad-io/.credentials ] && echo "absorbing $HOME/.koad-io/.credentials" && set -a && source $HOME/.koad-io/.credentials 
[ -f $HOME/.koad-io/.aliases ] && echo "absorbing $HOME/.koad-io/.aliases" && set -a && source $HOME/.koad-io/.aliases 

# Convert ENTITY to lowercase for directory naming.
# Guard against empty ENTITY — otherwise ENTITY_DIR falls back to "$HOME/."
# which sources $HOME/.env on every no-entity invocation (latent bug 2026-04-21).
[[ -z "$ENTITY_DIR" ]] && [[ -n "$ENTITY" ]] && ENTITY_DIR="$HOME/.$(echo "$ENTITY" | tr '[:upper:]' '[:lower:]')"

# Check and load any environment details from the entity's folder.
if [ -d "$ENTITY_DIR" ]; then
    [ -f $ENTITY_DIR/.env ] && echo "absorbing $ENTITY_DIR/.env" && set -a && source $ENTITY_DIR/.env 
    [ -f $ENTITY_DIR/.credentials ] && echo "absorbing $ENTITY_DIR/.credentials" && set -a && source $ENTITY_DIR/.credentials 
else
    echo "No configurations found for entity: $ENTITY"
fi

set +a

echo "-"
# Framework commands — PATH-style search path, first entry = highest priority.
# Falls back to ~/.koad-io/commands if KOAD_IO_COMMANDS_DIRS is unset.
# Kept KOAD_IO_COMMANDS_DIR pointing at the framework dir for any legacy consumer.
KOAD_IO_COMMANDS_DIRS="${KOAD_IO_COMMANDS_DIRS:-$HOME/.koad-io/commands}"
KOAD_IO_COMMANDS_DIR="$HOME/.koad-io/commands"
[[ $DEBUG ]] && echo "KOAD_IO_COMMANDS_DIRS=$KOAD_IO_COMMANDS_DIRS";

ENTITY_COMMANDS_DIR="$ENTITY_DIR/commands"
[[ $DEBUG ]] && echo "ENTITY_COMMANDS_DIR=$ENTITY_COMMANDS_DIR";

# Parse the commands path into an array and check any exist
IFS=':' read -ra _KOAD_IO_CMD_DIRS <<< "$KOAD_IO_COMMANDS_DIRS"
_ANY_FRAMEWORK_CMD_DIR=0
for _d in "${_KOAD_IO_CMD_DIRS[@]}"; do [[ -d $_d ]] && _ANY_FRAMEWORK_CMD_DIR=1 && break; done

# Check to see if we even have a command directory of that name or a file of the same name in the current working directory.  If not, then bail.
[[ $_ANY_FRAMEWORK_CMD_DIR -eq 0 ]] && [[ ! -d $ENTITY_COMMANDS_DIR ]] && [[ ! -d $PWD/commands/ ]]  && [[ ! -f $PWD/$1.sh ]] && echo "Cannot find that command, sorry..[command does not exist]" >&2 && exit 66;

# Command resolution: find the deepest matching command directory.
# Priority: CWD > entity > framework (higher priority can override, but only at equal or greater depth).
# This prevents a shallow entity folder from stomping a deeper framework command.
# note: we limit our abilities here by hard-wiring $1 thru $7 $8, this should not be hard-wired.
#
# Historical bug: depth-2+ lines used to carry `[[ ! -e $N ]]` CWD-existence
# guards. Those guards silently broke dispatch whenever a rooted entity ran
# `<entity> harness opencode` a second time — because the first run creates
# `$ENTITY_DIR/opencode/` as its XDG state dir, which then shadows the
# depth-2 sub-command path segment and collapses routing to `harness/`
# (producing "unknown harness 'opencode'"). The guard had no meaningful
# purpose at depth ≥ 2: intermediate positional args are sub-command names,
# not direct file arguments. Removed from depths 2-5 in all three sections
# (framework / entity / CWD). Depth-1 guard preserved — may still carry
# "treat $1 as a local script if it exists" semantics worth not touching.

COMMAND_DEPTH=0

# find deepest globally available command, iterating KOAD_IO_COMMANDS_DIRS.
# List is PATH-style (first = highest priority); we iterate in reverse so that
# the "later scan wins at equal depth" rule naturally lets the first-listed
# dir win (it gets scanned last).
for ((_i=${#_KOAD_IO_CMD_DIRS[@]}-1; _i>=0; _i--)); do
    _D="${_KOAD_IO_CMD_DIRS[$_i]}"
    [[ -z $_D ]] || [[ ! -d $_D ]] && continue
    [[ $1 ]] && [[ ! -e $1 ]] && [[ -d $_D/$1/ ]]             && [[ 1 -ge $COMMAND_DEPTH ]] && COMMAND_DEPTH=1 && COMMAND_LOCATION="$_D/$1"             && COMMAND_NAME=$1 && EXEC_ARGS=($2 $3 $4 $5 $6 $7 $8) && [[ $DEBUG ]] && echo "Found command directory: $COMMAND_LOCATION (depth $COMMAND_DEPTH)";
    [[ $2 ]] &&[[ -d $_D/$1/$2 ]]           && [[ 2 -ge $COMMAND_DEPTH ]] && COMMAND_DEPTH=2 && COMMAND_LOCATION="$_D/$1/$2"          && COMMAND_NAME=$2 && EXEC_ARGS=($3 $4 $5 $6 $7 $8)    && [[ $DEBUG ]] && echo "Found command directory: $COMMAND_LOCATION (depth $COMMAND_DEPTH)";
    [[ $3 ]] &&[[ -d $_D/$1/$2/$3/ ]]       && [[ 3 -ge $COMMAND_DEPTH ]] && COMMAND_DEPTH=3 && COMMAND_LOCATION="$_D/$1/$2/$3"       && COMMAND_NAME=$3 && EXEC_ARGS=($4 $5 $6 $7 $8)       && [[ $DEBUG ]] && echo "Found command directory: $COMMAND_LOCATION (depth $COMMAND_DEPTH)";
    [[ $4 ]] &&[[ -d $_D/$1/$2/$3/$4/ ]]    && [[ 4 -ge $COMMAND_DEPTH ]] && COMMAND_DEPTH=4 && COMMAND_LOCATION="$_D/$1/$2/$3/$4"    && COMMAND_NAME=$4 && EXEC_ARGS=($5 $6 $7 $8)          && [[ $DEBUG ]] && echo "Found command directory: $COMMAND_LOCATION (depth $COMMAND_DEPTH)";
    [[ $5 ]] &&[[ -d $_D/$1/$2/$3/$4/$5/ ]] && [[ 5 -ge $COMMAND_DEPTH ]] && COMMAND_DEPTH=5 && COMMAND_LOCATION="$_D/$1/$2/$3/$4/$5" && COMMAND_NAME=$5 && EXEC_ARGS=($6 $7 $8)             && [[ $DEBUG ]] && echo "Found command directory: $COMMAND_LOCATION (depth $COMMAND_DEPTH)";
done

# find deepest command from entity (only overrides framework at equal or greater depth)
[[ $1 ]] && [[ ! -e $1 ]] && [[ -d $ENTITY_COMMANDS_DIR/$1/ ]]               && [[ 1 -ge $COMMAND_DEPTH ]] && COMMAND_DEPTH=1 && COMMAND_LOCATION="$ENTITY_COMMANDS_DIR/$1"              && COMMAND_NAME=$1 && EXEC_ARGS=("$2 $3 $4 $5 $6 $7 $8") && [[ $DEBUG ]] && echo "Found command directory: $COMMAND_LOCATION (depth $COMMAND_DEPTH)";
[[ $2 ]] &&[[ -d $ENTITY_COMMANDS_DIR/$1/$2/ ]]            && [[ 2 -ge $COMMAND_DEPTH ]] && COMMAND_DEPTH=2 && COMMAND_LOCATION="$ENTITY_COMMANDS_DIR/$1/$2"           && COMMAND_NAME=$2 && EXEC_ARGS=("$3 $4 $5 $6 $7 $8")    && [[ $DEBUG ]] && echo "Found command directory: $COMMAND_LOCATION (depth $COMMAND_DEPTH)";
[[ $3 ]] &&[[ -d $ENTITY_COMMANDS_DIR/$1/$2/$3/ ]]         && [[ 3 -ge $COMMAND_DEPTH ]] && COMMAND_DEPTH=3 && COMMAND_LOCATION="$ENTITY_COMMANDS_DIR/$1/$2/$3"        && COMMAND_NAME=$3 && EXEC_ARGS=("$4 $5 $6 $7 $8")       && [[ $DEBUG ]] && echo "Found command directory: $COMMAND_LOCATION (depth $COMMAND_DEPTH)";
[[ $4 ]] &&[[ -d $ENTITY_COMMANDS_DIR/$1/$2/$3/$4/ ]]      && [[ 4 -ge $COMMAND_DEPTH ]] && COMMAND_DEPTH=4 && COMMAND_LOCATION="$ENTITY_COMMANDS_DIR/$1/$2/$3/$4"     && COMMAND_NAME=$4 && EXEC_ARGS=("$5 $6 $7 $8")          && [[ $DEBUG ]] && echo "Found command directory: $COMMAND_LOCATION (depth $COMMAND_DEPTH)";
[[ $5 ]] &&[[ -d $ENTITY_COMMANDS_DIR/$1/$2/$3/$4/$5/ ]]   && [[ 5 -ge $COMMAND_DEPTH ]] && COMMAND_DEPTH=5 && COMMAND_LOCATION="$ENTITY_COMMANDS_DIR/$1/$2/$3/$4/$5"  && COMMAND_NAME=$5 && EXEC_ARGS=("$6 $7 $8")             && [[ $DEBUG ]] && echo "Found command directory: $COMMAND_LOCATION (depth $COMMAND_DEPTH)";

# find deepest command from current working directory's command folder (only overrides at equal or greater depth)
[[ $1 ]] && [[ ! -e $1 ]] && [[ -d $CWD/commands/$1/ ]]             && [[ 1 -ge $COMMAND_DEPTH ]] && COMMAND_DEPTH=1 && COMMAND_LOCATION="$CWD/commands/$1"             && COMMAND_NAME=$1 && EXEC_ARGS=("$2 $3 $4 $5 $6 $7 $8") && [[ $DEBUG ]] && echo "Found command directory: $COMMAND_LOCATION (depth $COMMAND_DEPTH)";
[[ $2 ]] &&[[ -d $CWD/commands/$1/$2/ ]]          && [[ 2 -ge $COMMAND_DEPTH ]] && COMMAND_DEPTH=2 && COMMAND_LOCATION="$CWD/commands/$1/$2"          && COMMAND_NAME=$2 && EXEC_ARGS=("$3 $4 $5 $6 $7 $8")    && [[ $DEBUG ]] && echo "Found command directory: $COMMAND_LOCATION (depth $COMMAND_DEPTH)";
[[ $3 ]] &&[[ -d $CWD/commands/$1/$2/$3/ ]]       && [[ 3 -ge $COMMAND_DEPTH ]] && COMMAND_DEPTH=3 && COMMAND_LOCATION="$CWD/commands/$1/$2/$3"       && COMMAND_NAME=$3 && EXEC_ARGS=("$4 $5 $6 $7 $8")       && [[ $DEBUG ]] && echo "Found command directory: $COMMAND_LOCATION (depth $COMMAND_DEPTH)";
[[ $4 ]] &&[[ -d $CWD/commands/$1/$2/$3/$4/ ]]    && [[ 4 -ge $COMMAND_DEPTH ]] && COMMAND_DEPTH=4 && COMMAND_LOCATION="$CWD/commands/$1/$2/$3/$4"    && COMMAND_NAME=$4 && EXEC_ARGS=("$5 $6 $7 $8")          && [[ $DEBUG ]] && echo "Found command directory: $COMMAND_LOCATION (depth $COMMAND_DEPTH)";
[[ $5 ]] &&[[ -d $CWD/commands/$1/$2/$3/$4/$5/ ]] && [[ 5 -ge $COMMAND_DEPTH ]] && COMMAND_DEPTH=5 && COMMAND_LOCATION="$CWD/commands/$1/$2/$3/$4/$5" && COMMAND_NAME=$5 && EXEC_ARGS=("$6 $7 $8")             && [[ $DEBUG ]] && echo "Found command directory: $COMMAND_LOCATION (depth $COMMAND_DEPTH)";

[[ $DEBUG ]] && echo

[[ $COMMAND_LOCATION ]] && [[ $DEBUG ]] && echo "POTENTIAL_COMMAND: $COMMAND_NAME"
[[ $COMMAND_LOCATION ]] && [[ $DEBUG ]] && echo "POTENTIAL_EXEC_ARGS: ${EXEC_ARGS[@]}"
[[ $COMMAND_LOCATION ]] && [[ $DEBUG ]] && echo

[[ $COMMAND_LOCATION ]] && POTENTIAL_NAMED_COMMAND=${EXEC_ARGS[0]} && EXEC_ARGS=${EXEC_ARGS[@]} && [[ $DEBUG ]] && echo "POTENTIAL_NAMED_COMMAND: $POTENTIAL_NAMED_COMMAND" 
[[ $COMMAND_LOCATION ]] && POTENTIAL_REMAINDER_ARGUMENTS=("${EXEC_ARGS[@]}") && unset POTENTIAL_REMAINDER_ARGUMENTS[0] && [[ $DEBUG ]] && echo "POTENTIAL_REMAINDER_ARGUMENTS: ${POTENTIAL_REMAINDER_ARGUMENTS[@]}" && echo

# command file can either be named `command.sh` or have the same name as the command with .sh extension
[[ -f $COMMAND_LOCATION/command.sh ]]                  && echo "command.sh is found in $COMMAND_LOCATION" >&2                     && export EXEC_FILE="$COMMAND_LOCATION/command.sh";

[[ $DEBUG ]] && echo "checking for $COMMAND_LOCATION/$POTENTIAL_NAMED_COMMAND.sh"
[[ -f $COMMAND_LOCATION/$POTENTIAL_NAMED_COMMAND.sh ]] && echo "$POTENTIAL_NAMED_COMMAND.sh is found in $COMMAND_LOCATION" >&2 && EXEC_ARGS="${POTENTIAL_REMAINDER_ARGUMENTS[@]}" && export EXEC_FILE="$COMMAND_LOCATION/$POTENTIAL_NAMED_COMMAND.sh";

# finally, find a command from current working directory of the same name
[[ -f $CWD/$1.sh ]] && echo "$1.sh is found in $CWD" >&2 &&  EXEC_ARGS="$2 $3 $4 $5 $6 $7 $8"&& export EXEC_FILE="$CWD/$1.sh" && COMMAND_LOCATION=$CWD;

# Make sure we have a valid command file to run, else crash 66
[[ ! -n $EXEC_FILE ]] && echo "Could not find command file to execute, sorry." && echo "EXEC_FILE: $EXEC_FILE" >&2 && exit 66;

# If the working directory contains environment and credentials, load them
[ -f $COMMAND_LOCATION/.env ]         && echo "loading $COMMAND_LOCATION/.env"         && set -a && source $COMMAND_LOCATION/.env 
[ -f $COMMAND_LOCATION/.credentials ] && echo "loading $COMMAND_LOCATION/.credentials" && set -a && source $COMMAND_LOCATION/.credentials 


export COMMAND_LOCATION=$COMMAND_LOCATION

# if DEBUG is set, barf out some details.
[[ $DEBUG ]] && echo
[[ $DEBUG ]] && echo "COMMAND_LOCATION=$COMMAND_LOCATION";
[[ $DEBUG ]] && echo "EXEC_FILE=$EXEC_FILE";
[[ $DEBUG ]] && echo "EXEC_ARGS=$EXEC_ARGS";
[[ $DEBUG ]] && echo

# Check if the --dry-run flag is set (now in KOAD_IO_FLAGS, not $@)
if [[ "$KOAD_IO_FLAGS" == *"--dry-run"* ]]; then
  export DRY_RUN=true
fi

echo "--exec $EXEC_FILE $EXEC_ARGS $KOAD_IO_FLAGS"


if [ "$DRY_RUN" = true ]; then
	echo "Dry run, stopped..."
else
	# All is well, lets go!
	# EXEC_ARGS is a space-separated string built from positional $N vars — word-split
	# intentionally (these are sub-command names, never contain spaces).
	# _flag_args is the bash array from the separation loop above; quoted expansion
	# preserves whitespace inside flag values (Fix B).
	# shellcheck disable=SC2086
	exec $EXEC_FILE $EXEC_ARGS "${_flag_args[@]}"
fi
