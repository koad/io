#!/usr/bin/env bash
# think — hit ollama on fourty4 for local inference
# Usage: think "your prompt" [--model <model>]
#        echo "prompt" | think [--model <model>]
#
# Models available on fourty4:
#   deepseek-r1:8b      128k context, strong reasoning (default for research)
#   llama3.2:latest     128k context, fast general language
#   qwen2.5-coder:32b   32k context, code generation
#   qwen2.5-coder:1.5b  32k context, quick code tasks
#   gemma3:1b           32k context, lightweight background tasks

FOURTY4_OLLAMA="http://10.10.10.11:11434"
DEFAULT_MODEL="llama3.2:latest"
MODEL="$DEFAULT_MODEL"
PROMPT=""

# Parse args
while [[ $# -gt 0 ]]; do
  case "$1" in
    --model|-m)
      MODEL="$2"
      shift 2
      ;;
    *)
      PROMPT="$1"
      shift
      ;;
  esac
done

# Read from stdin if no prompt arg
if [[ -z "$PROMPT" ]]; then
  PROMPT=$(cat)
fi

if [[ -z "$PROMPT" ]]; then
  echo "Usage: think \"your prompt\" [--model <model>]" >&2
  echo "       echo \"prompt\" | think [--model <model>]" >&2
  echo "" >&2
  echo "Models: deepseek-r1:8b | llama3.2:latest | qwen2.5-coder:32b | qwen2.5-coder:1.5b | gemma3:1b" >&2
  exit 1
fi

# Stream response from ollama
curl -sf "$FOURTY4_OLLAMA/api/generate" \
  -H "Content-Type: application/json" \
  -d "$(jq -n --arg model "$MODEL" --arg prompt "$PROMPT" \
    '{model: $model, prompt: $prompt, stream: true}')" \
  | while IFS= read -r line; do
      echo "$line" | jq -r '.response // empty' 2>/dev/null
    done
