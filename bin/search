#!/usr/bin/env bash
# koad:io unified search — waterfalls through the entire kingdom
# Knows the topology so nobody has to remember where things live.
#
# Modes:
#   search <pattern>                 — text search all entities + framework
#   search --where key=value         — frontmatter query across kingdom
#   search --related <file>          — find everything connected to a file
#   search --stale [days]            — find forgotten work (non-done, untouched)
#   search --atlas                   — kingdom dashboard grouped by status
#   search --echo <topic>            — fuzzy topic match on titles/descriptions
#
# Uses ripgrep (rg) if available, falls back to grep -rn.

set -euo pipefail

PATTERN=""
ONLY_ENTITY=""
ONLY_FRAMEWORK=""
SKIP_COMPLETE=""
LIMIT=0
FROM_MODE="fs"
MODE="search"  # search | related | stale | atlas | echo
MODE_ARG=""
STALE_DAYS=7
KOAD_IO_DIR="${KOAD_IO_DIR:-$HOME/.koad-io}"
declare -a WHERE_CLAUSES=()
declare -a SEARCH_ROOTS=()

if [[ -n "${KOAD_IO_SEARCH_ROOTS:-}" ]]; then
  IFS=':' read -ra SEARCH_ROOTS <<< "$KOAD_IO_SEARCH_ROOTS"
fi

_DONE_STATUSES="landed|shipped|archived|canonical|complete|completed|delivered|closed|merged|resolved"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --entity)         ONLY_ENTITY="$2"; shift 2 ;;
    --framework)      ONLY_FRAMEWORK=1; shift ;;
    --from)           FROM_MODE="$2"; shift 2 ;;
    --skip-complete)  SKIP_COMPLETE=1; shift ;;
    --limit)          LIMIT="$2"; shift 2 ;;
    --where)          WHERE_CLAUSES+=("$2"); shift 2 ;;
    --related)        MODE="related"; MODE_ARG="$2"; shift 2 ;;
    --stale)          MODE="stale"
                      if [[ "${2:-}" =~ ^[0-9]+$ ]]; then
                        STALE_DAYS="$2"; shift 2
                      else
                        shift
                      fi ;;
    --atlas)          MODE="atlas"; shift ;;
    --echo)           MODE="echo"; MODE_ARG="$2"; shift 2 ;;
    --help|-h)
      cat <<'USAGE'
search [<pattern>] [options]

Kingdom-wide search across all operational folders.

Modes:
  search <pattern>              Text search (grep)
  search --where key=value      Frontmatter query (list matching files)
  search <pattern> --where ...  Text search filtered by frontmatter
  search --related <file>       Find everything connected to a file
  search --stale [days]         Find forgotten work (default: 7 days untouched)
  search --atlas                Kingdom dashboard — all work grouped by status
  search --echo <topic>         Fuzzy topic match on titles and descriptions

Source options:
  --from db                    Query Postgres juno_drift.documents instead of filesystem grep
                               (falls back to filesystem search if PG is unavailable)

Where mode (--where):
  Frontmatter search across the kingdom. Operates on YAML frontmatter in .md files.
  Multiple --where flags combine as AND conditions.

  Operators:
    key=value     Exact match (case-insensitive)  — status=draft
    key!=value    Not equal                       — status!=landed
    key~value     Contains / partial match        — entities~vulcan
                   (for arrays: matches if any element contains value;
                    for scalars: substring match)

  Keys work across the canonical frontmatter vocabulary:
    status, priority, kind, type, author, from, to, entities, tags, date, title

  Combining with text search:
    search "telemetry" --where entity=juno     text+grep filtered to one entity
    search --where "status=ready" "priority=high"   multiple AND conditions

Options:
  --entity X         Narrow to one entity
  --framework        Framework dirs only
  --limit N          Cap output lines (default: unlimited)
  --skip-complete    Skip .md files whose frontmatter status is done
                     (landed, shipped, archived, canonical, complete,
                      completed, delivered, closed, merged, resolved)

Examples:
  search "telemetry"                             # text across kingdom
  search --where status=draft                    # all drafts
  search --where "priority=high" --skip-complete # high-pri, still open
  search --where entities~vulcan                 # files mentioning vulcan
  search --where "status=ready" "priority=high"  # ready AND high priority
  search "error" --where status=ready --limit 20 # text + where, capped
  search --related ~/.juno/briefs/daemon-flight-telemetry.md
  search --stale 14                              # untouched for 2 weeks
  search --atlas                                 # the big picture
  search --echo "oauth"                          # anything about oauth
  search "telemetry" --from db --entity juno     # FTS via juno_drift
USAGE
      exit 0
      ;;
    -*)  echo "unknown flag: $1" >&2; exit 1 ;;
    *)   PATTERN="$1"; shift ;;
  esac
done

# --- Validate mode ---
if [[ "$MODE" == "search" ]] && [[ -z "$PATTERN" ]] && [[ ${#WHERE_CLAUSES[@]} -eq 0 ]]; then
  echo "usage: search [<pattern>] [--where key=value] [--related <file>] [--stale [days]] [--atlas] [--echo <topic>]" >&2
  exit 1
fi

# --- Search engine ---
_NOISE_DIRS=(.git node_modules .npm .meteor packages .claude .opencode .local .trash trash .archive archive builds isopacks dist id .vscode-oss)
_NOISE_FILES=(.context '*.asc' '*.gpg' '*.pub' '*.pem')

_scope_enabled() {
  [[ ${#SEARCH_ROOTS[@]} -gt 0 ]]
}

_scope_allows() {
  local _target="$1"
  if ! _scope_enabled; then
    return 0
  fi

  local _target_real
  _target_real="$(realpath -m "$_target" 2>/dev/null || echo "$_target")"

  for _root in "${SEARCH_ROOTS[@]}"; do
    [[ -n "$_root" ]] || continue
    local _root_real
    _root_real="$(realpath -m "$_root" 2>/dev/null || echo "$_root")"
    case "$_target_real/" in
      "$_root_real/"*) return 0 ;;
    esac
  done

  return 1
}

if command -v rg &>/dev/null; then
  _search_raw() {
    local _args=(--no-heading --line-number --color=always)
    for _d in "${_NOISE_DIRS[@]}"; do _args+=(--glob "!$_d"); done
    for _f in "${_NOISE_FILES[@]}"; do _args+=(--glob "!$_f"); done
    rg "${_args[@]}" "$PATTERN" "$@" 2>/dev/null || true
  }
else
  _search_raw() {
    local _args=(-rn --color=always)
    for _d in "${_NOISE_DIRS[@]}"; do _args+=(--exclude-dir="$_d"); done
    for _f in "${_NOISE_FILES[@]}"; do _args+=(--exclude="$_f"); done
    grep "${_args[@]}" "$PATTERN" "$@" 2>/dev/null || true
  }
fi

# --- Frontmatter reader ---
_read_frontmatter() {
  local _file="$1"
  [[ -f "$_file" ]] || return 1
  awk '
    NR==1 && /^---/ { in_fm=1; next }
    in_fm && /^---/ { exit }
    in_fm { print }
  ' "$_file" 2>/dev/null
}

# --- Get a single frontmatter value ---
_fm_val() {
  local _file="$1" _key="$2"
  _read_frontmatter "$_file" | { grep -iE "^${_key}:" || true; } | head -1 | sed "s/^[^:]*:\s*//" | sed 's/^"\(.*\)"$/\1/'
}

# --- Where clause evaluator ---
_matches_where() {
  local _file="$1"
  [[ "$_file" == *.md ]] || return 1
  [[ -f "$_file" ]] || return 1

  local _fm
  _fm="$(_read_frontmatter "$_file")"
  [[ -n "$_fm" ]] || return 1

  for _clause in "${WHERE_CLAUSES[@]}"; do
    local _key _op _val

    if [[ "$_clause" == *"!="* ]]; then
      _op="!="
      _key="${_clause%%!=*}"
      _val="${_clause#*!=}"
    elif [[ "$_clause" == *"~"* ]]; then
      _op="~"
      _key="${_clause%%~*}"
      _val="${_clause#*~}"
    elif [[ "$_clause" == *"="* ]]; then
      _op="="
      _key="${_clause%%=*}"
      _val="${_clause#*=}"
    else
      return 1
    fi

    local _fm_val
    _fm_val="$(echo "$_fm" | grep -iE "^${_key}:" | head -1 | sed "s/^[^:]*:\s*//")"

    case "$_op" in
      "=")  [[ "${_fm_val,,}" == "${_val,,}" ]] || return 1 ;;
      "!=") [[ -n "$_fm_val" ]] && [[ "${_fm_val,,}" == "${_val,,}" ]] && return 1 ;;
      "~")  [[ "${_fm_val,,}" == *"${_val,,}"* ]] || return 1 ;;
    esac
  done
  return 0
}

# --- Completion filter ---
_is_complete() {
  local _file="$1"
  [[ "$_file" == *.md ]] || return 1
  [[ -f "$_file" ]] || return 1
  head -15 "$_file" 2>/dev/null | grep -qiE "^status:\s*($_DONE_STATUSES)" && return 0
  return 1
}

# --- Filter & display ---
_filter_result() {
  local _file="$1"
  [[ -n "$SKIP_COMPLETE" ]] && _is_complete "$_file" && return 0
  [[ ${#WHERE_CLAUSES[@]} -gt 0 ]] && ! _matches_where "$_file" && return 0
  return 1
}

# --- Dedup + limit output ---
_format_output() {
  local _result="$1"
  local _filtered="" _prev_file="" _prev_skip=""
  local _count=0
  while IFS= read -r _line; do
    local _clean
    _clean="$(echo "$_line" | sed 's/\x1b\[[0-9;]*m//g')"
    local _file
    _file="$(echo "$_clean" | cut -d: -f1)"
    if [[ "$_file" == "$_prev_file" ]] && [[ -n "$_prev_skip" ]]; then
      continue
    fi
    _prev_file="$_file"
    _prev_skip="$SKIP_COMPLETE"
    _filtered="$_filtered$_line"$'\n'
    _count=$((_count + 1))
    [[ $LIMIT -gt 0 ]] && [[ $_count -ge $LIMIT ]] && break
  done <<< "$_result"
  [[ -n "$_filtered" ]] && echo "$_filtered"
}

# --- Pretty-print a markdown file ---
_display_md() {
  local _file="$1"
  local _title _status _priority
  _title="$(_fm_val "$_file" title)"
  _status="$(_fm_val "$_file" status)"
  _priority="$(_fm_val "$_file" priority)"
  local _display
  _display="$(printf '\033[0;36m%s\033[0m  ' "$_file")"
  [[ -n "$_title" ]] && _display="$_display$(printf '\033[0;33m%s\033[0m  ' "$_title")"
  [[ -n "$_status" ]] && _display="$_display$(printf '\033[0;35m[%s]\033[0m  ' "$_status")"
  [[ -n "$_priority" ]] && _display="$_display$(printf '\033[0;31m(%s)\033[0m' "$_priority")"
  echo "$_display"
}

# --- Build exclude args for find ---
_exclude_find() {
  local _dir="$1"
  shift
  local _exclude_args=()
  for _d in "${_NOISE_DIRS[@]}"; do
    _exclude_args+=(-not -path "*/$_d/*")
  done
  echo "${_exclude_args[@]}"
}

# --- Operational directories inside an entity ---
_op_dirs=(
  briefs assessments memories skills reports specs
  tickler messages commands hooks harvest docs
)

# --- Search one entity ---
_search_entity() {
  local _name="$1"
  local _dir="$2"
  local _entity_found=0

  # Text + where search
  if [[ -n "$PATTERN" ]]; then
    for _rel in "${_op_dirs[@]}"; do
      local _path="$_dir/$_rel"
      [[ -d "$_path" ]] || continue
      local _result
      _result="$(_search_raw "$_path" 2>/dev/null)" || true
      [[ -n "$_result" ]] || continue
      _result="$(_format_output "$_result")"
      [[ -n "$_result" ]] || continue
      [[ $_entity_found -eq 0 ]] && printf '\033[1m── %s ──\033[0m\n' "$_name"
      _entity_found=1
      printf '\033[1;34m%s/\033[0m\n' "$_rel"
      echo "$_result"
      echo
    done
  fi

  # Where-only search (no text pattern)
  if [[ -z "$PATTERN" ]] && [[ ${#WHERE_CLAUSES[@]} -gt 0 ]]; then
    for _rel in "${_op_dirs[@]}"; do
      local _path="$_dir/$_rel"
      [[ -d "$_path" ]] || continue
      local _result
      _result=$(find "$_path" -name '*.md' $(_exclude_find "$_path") 2>/dev/null | while read -r _file; do
        _matches_where "$_file" || continue
        [[ -n "$SKIP_COMPLETE" ]] && _is_complete "$_file" && continue
        _display_md "$_file"
      done)
      [[ -n "$_result" ]] || continue
      _result="$(_format_output "$_result")"
      [[ -n "$_result" ]] || continue
      [[ $_entity_found -eq 0 ]] && printf '\033[1m── %s ──\033[0m\n' "$_name"
      _entity_found=1
      printf '\033[1;34m%s/\033[0m\n' "$_rel"
      echo "$_result"
      echo
    done
  fi

  return $(( _entity_found == 0 ))
}

# --- Search framework ---
_search_framework() {
  local _fw_dirs=(commands harness skeletons helpers bin)
  local _fw_found=0

  if [[ -z "$PATTERN" ]] && [[ ${#WHERE_CLAUSES[@]} -eq 0 ]]; then
    return 1
  fi

  for _rel in "${_fw_dirs[@]}"; do
    local _dir="$KOAD_IO_DIR/$_rel"
    [[ -d "$_dir" ]] || continue
    if [[ -n "$PATTERN" ]]; then
      local _result
      _result="$(_search_raw "$_dir" 2>/dev/null)" || true
      [[ -n "$_result" ]] || continue
      _result="$(_format_output "$_result")"
      [[ -n "$_result" ]] || continue
      [[ $_fw_found -eq 0 ]] && printf '\033[1m── framework ──\033[0m\n'
      _fw_found=1
      printf '\033[1;34m%s/\033[0m\n' "$_rel"
      echo "$_result"
      echo
    else
      local _result
      _result=$(find "$_dir" -name '*.md' $(_exclude_find "$_dir") 2>/dev/null | while read -r _file; do
        _matches_where "$_file" || continue
        [[ -n "$SKIP_COMPLETE" ]] && _is_complete "$_file" && continue
        _display_md "$_file"
      done)
      [[ -n "$_result" ]] || continue
      _result="$(_format_output "$_result")"
      [[ -n "$_result" ]] || continue
      [[ $_fw_found -eq 0 ]] && printf '\033[1m── framework ──\033[0m\n'
      _fw_found=1
      printf '\033[1;34m%s/\033[0m\n' "$_rel"
      echo "$_result"
      echo
    fi
  done

  return $(( _fw_found == 0 ))
}

# --- List all entities ---
_list_entities() {
  for _d in "$HOME"/.*/; do
    local _name
    _name="$(basename "$_d")"
    [[ "$_name" == "." ]] && continue
    [[ "$_name" == ".." ]] && continue
    [[ ! -d "$_d" ]] && continue
    [[ -f "$_d/ENTITY.md" ]] || continue
    [[ -n "$(find "$_d" -maxdepth 1 -name 'ENTITY.md' | head -1)" ]] || continue
    local _dir="$HOME/.$_name"
    _scope_allows "$_dir" || continue
    echo "$_name"
  done
}

# --- Apply limit to output (post-filter hook) ---
_limit_output() {
  if [[ $LIMIT -gt 0 ]]; then
    head -n "$LIMIT"
  else
    cat
  fi
}

# MODE: --from db
_mode_db_search() {
  if [[ -z "$PATTERN" ]]; then
    echo "search --from db requires a text pattern; falling back to filesystem search" >&2
    return 2
  fi
  if [[ ${#WHERE_CLAUSES[@]} -gt 0 ]]; then
    echo "search --from db: --where is not SQL-backed yet; falling back to filesystem search" >&2
    return 2
  fi
  if [[ -n "$ONLY_FRAMEWORK" ]]; then
    echo "search --from db: --framework is filesystem-only; falling back to filesystem search" >&2
    return 2
  fi
  if ! command -v psql &>/dev/null; then
    echo "search --from db: psql not found; falling back to filesystem search" >&2
    return 2
  fi

  local _pg_host="${KOAD_PG_HOST:-${KOAD_IO_RUNTIME_PATH:-$HOME/.local/share/koad-io/runtime}/postgres}"
  local _pg_port="${KOAD_PG_PORT:-28432}"
  local _pg_user="${KOAD_PG_USER:-koad}"
  local _pg_db="${KOAD_PG_DRIFT_DB:-juno_drift}"
  local _rows
  local _sql
  _sql="
    SELECT d.file_path, d.entity, ts_headline('english', d.body, plainto_tsquery('english', :'q'),
      'StartSel=' || chr(27) || '[1m' || chr(27) || '[31m, StopSel=' || chr(27) || '[0m,
       MaxWords=120, MinWords=30, ShortWord=2, MaxFragments=4, FragmentDelimiter=' || chr(27) || '[0m…' || chr(27) || '[1m' || chr(27) || '[31m')
    FROM juno_drift.documents d
    LEFT JOIN juno_drift.entity_tombstones v ON d.file_path = v.file_path
    WHERE d.body_tsv @@ plainto_tsquery('english', :'q')
      AND (
        d.searchable = true
        OR (d.searchable IS NULL AND d.content_type IN ('text/markdown', 'text/plain', 'application/json'))
      )
      AND (v.tombstoned_at IS NULL OR d.updated_at > v.tombstoned_at)
      AND (:entity = '' OR d.entity = :entity)
      AND (:skip_complete = '' OR d.status NOT IN ('landed','shipped','archived','canonical','complete','completed','delivered','closed','merged','resolved'))
    ORDER BY ts_rank(d.body_tsv, plainto_tsquery('english', :'q')) DESC
    LIMIT 50;
  "
  if ! _rows=$(psql -h "$_pg_host" -p "$_pg_port" -U "$_pg_user" -d "$_pg_db" -X -q -t -A -F $'\x1f' -v ON_ERROR_STOP=1 -v q="$PATTERN" -v entity="$ONLY_ENTITY" -v skip_complete="$SKIP_COMPLETE" 2>/dev/null <<< "$_sql"); then
    echo "search --from db: juno_drift unavailable; falling back to filesystem search" >&2
    return 2
  fi

  if [[ -z "$_rows" ]]; then
    echo "no db matches for '$PATTERN'"
    return 0
  fi

  local _count=0
  while IFS=$'\x1f' read -r _path _entity _headline; do
    _count=$((_count + 1))
    printf '\033[0;36m%s\033[0m  \033[0;90m[%s]\033[0m\n' "$_path" "$_entity"
    printf '  %s\n\n' "$_headline"
    [[ $LIMIT -gt 0 ]] && [[ $_count -ge $LIMIT ]] && break
  done <<< "$_rows"
  return 0
}

# MODE: --related <file>
_mode_related() {
  local _file="$1"

  if [[ ! -f "$_file" ]]; then
    echo "error: file not found: $_file" >&2
    return 1
  fi

  if ! _scope_allows "$_file"; then
    echo "error: related file is outside search scope: $_file" >&2
    return 1
  fi

  printf '\033[1m── related to: %s ──\033[0m\n\n' "$(basename "$_file")"

  # Read frontmatter to extract references
  local _fm
  _fm="$(_read_frontmatter "$_file")"

  # Multi-line YAML list parser: extract items from relates-to, refs, etc.
  _extract_list_values() {
    local _key="$1"
    local _line
    _line="$(echo "$_fm" | { grep -iE "^${_key}:" || true; } | head -1)"
    [[ -z "$_line" ]] && return
    local _inline
    _inline="$(echo "$_line" | sed "s/^[^:]*:\s*//")"
    if [[ "$_inline" == "["*"]" ]]; then
      # Inline YAML list: [a, b, c]
      echo "$_inline" | tr -d '[]' | tr ',' '\n'
    elif [[ -z "$_inline" ]] || [[ "$_inline" =~ ^[[:space:]]*$ ]]; then
      # Multi-line YAML list (subsequent lines starting with "  - ")
      echo "$_fm" | awk -v key="$_key" '
        BEGIN { found=0 }
        $0 ~ "^"key":" { found=1; next }
        found && /^  - / { gsub(/^  - /, ""); print }
        found && !/^  - / && !/^[[:space:]]*$/ { exit }
      '
    else
      echo "$_inline"
    fi
  }

  # relates-to / related / see-also / depends-on
  local _all_refs=""
  for _key in relates-to related see-also depends-on refs references; do
    while IFS= read -r _ref; do
      [[ -z "$_ref" ]] && continue
      _ref="$(echo "$_ref" | sed 's/[[:space:]]*(.*//' | sed 's/^"//' | sed 's/"$//' | xargs)"
      [[ -z "$_ref" ]] && continue
      _all_refs="$_all_refs $_ref"
    done < <(_extract_list_values "$_key")
  done

  # Title and filename stem as additional search terms
  local _title
  _title="$(_fm_val "$_file" title)"
  [[ -n "$_title" ]] && _all_refs="$_all_refs $_title"

  local _stem
  _stem="$(basename "$_file" .md)"
  _all_refs="$_all_refs $_stem"

  # Also include any entity names referenced (looks like single-word handles)
  for _ref in $_all_refs; do
    # Extract entity handles from paths like ~/.juno/briefs/...
    local _ent
    _ent="$(echo "$_ref" | grep -oP '\.(juno|vulcan|muse|vesta|veritas|mercury|aegis|alice|rufus|sibyl|faber|rooty|iris|salus|livy|argus|janus|copia|fiscus|galen|chiron|astro|cacula|twoshoes|missouri|lyra|atlas)/?' || true)"
    _ent="$(echo "$_ent" | xargs)"
    [[ -n "$_ent" ]] && _all_refs="$_all_refs $_ent"
  done

  if [[ -z "$(echo "$_all_refs" | xargs)" ]]; then
    echo "no frontmatter references found to follow"
    echo ""
    echo "(Tip: add 'relates-to:', 'refs:', or 'references:' to your file's YAML frontmatter)"
    return 1
  fi

  # Build combined search terms
  local _combined=""
  for _ref in $_all_refs; do
    local _escaped
    _escaped="$(echo "$_ref" | sed 's/[][()\.^$*+?{}|]/\\&/g')"
    _combined="${_combined}${_escaped}|"
  done
  _combined="${_combined%|}"

  printf '\033[0;90mSearching for connections: %s\033[0m\n\n' "$(echo "$_all_refs" | xargs)"

  local _total_found=0
  local _src_clean
  _src_clean="$(realpath "$_file" 2>/dev/null || echo "$_file")"

  # Search each entity for files referencing the extracted terms
  local -a _entities_arr=()
  if [[ -n "$ONLY_ENTITY" ]]; then
    _entities_arr=("$ONLY_ENTITY")
  else
    mapfile -t _entities_arr < <(_list_entities | sort)
  fi

  for _name in "${_entities_arr[@]}"; do
    local _result
    _result="$(_search_entity "$_name" "$HOME/.$_name")" || true
    [[ -n "$_result" ]] || continue
    # Remove the source file from results
    _result="$(echo "$_result" | { grep -v "$_src_clean" || true; })"
    [[ -n "$_result" ]] || continue
    # Apply limit
    [[ $LIMIT -gt 0 ]] && _result="$(echo "$_result" | head -n "$LIMIT")"
    echo "$_result"
    _total_found=1
  done

  _search_framework 2>/dev/null || true

  if [[ $_total_found -eq 0 ]]; then
    echo "no connections found — no other files reference the extracted terms"
  fi

  return 0
}

# MODE: --stale [days]
_mode_stale() {
  local _days="$STALE_DAYS"
  local _cutoff
  _cutoff=$(date -d "$_days days ago" +%s 2>/dev/null || echo 0)
  [[ "$_cutoff" == "0" ]] && return 1

  local _found=0
  local -a _entities_arr=()
  if [[ -n "$ONLY_ENTITY" ]]; then
    _entities_arr=("$ONLY_ENTITY")
  else
    mapfile -t _entities_arr < <(_list_entities | sort)
  fi

  for _name in "${_entities_arr[@]}"; do
    local _dir="$HOME/.$_name"
    local _entity_found=0
    for _rel in "${_op_dirs[@]}"; do
      local _path="$_dir/$_rel"
      [[ -d "$_path" ]] || continue
      while IFS= read -r _md; do
        [[ -f "$_md" ]] || continue
        # Skip complete/done items
        if [[ -n "$SKIP_COMPLETE" ]]; then
          local _status
          _status="$(_fm_val "$_md" status)"
          [[ "$_status" =~ ^($_DONE_STATUSES)$ ]] && continue
        fi
        local _mtime
        _mtime=$(stat -c %Y "$_md" 2>/dev/null || echo 0)
        [[ "$_mtime" == "0" ]] && continue
        local _age=$(( ( $(date +%s) - _mtime ) / 86400 ))
        if [[ $_age -ge $_days ]]; then
          if [[ $_entity_found -eq 0 ]]; then
            printf '\033[1m── %s ──\033[0m\n' "$_name"
            _entity_found=1
          fi
          _display_md "$_md"
          echo "  (${_age}d untouched)"
          _found=1
        fi
      done < <(find "$_path" -name '*.md' $(_exclude_find "$_path") 2>/dev/null)
    done
    [[ $_entity_found -eq 1 ]] && echo
  done

  [[ $LIMIT -gt 0 ]] && return 0  # limit applied by caller
  [[ $_found -eq 0 ]] && echo "nothing stale — all active work is fresh"
  return 0
}

# MODE: --atlas
_mode_atlas() {
  local _total=0
  local -A _by_status=()

  local -a _entities_arr=()
  if [[ -n "$ONLY_ENTITY" ]]; then
    _entities_arr=("$ONLY_ENTITY")
  else
    mapfile -t _entities_arr < <(_list_entities | sort)
  fi

  for _name in "${_entities_arr[@]}"; do
    local _dir="$HOME/.$_name"
    for _rel in "${_op_dirs[@]}"; do
      local _path="$_dir/$_rel"
      [[ -d "$_path" ]] || continue
      while IFS= read -r _md; do
        [[ -f "$_md" ]] || continue
        local _status
        _status="$(_fm_val "$_md" status)"
        [[ -z "$_status" ]] && _status="untagged"
        local _norm
        _norm="$(echo "$_status" | awk '{print tolower($1)}' | tr -d '—-')"
        local _title
        _title="$(_fm_val "$_md" title)"
        local _entry
        _entry="$(printf '\033[0;36m%s\033[0m  \033[0;33m%s\033[0m  [\033[0;35m%s\033[0m]\n' "$_md" "${_title:-}" "$_status")"
        _by_status["$_norm"]="${_by_status[$_norm]}${_entry}"
        _total=$((_total + 1))
      done < <(find "$_path" -name '*.md' $(_exclude_find "$_path") 2>/dev/null)
    done
  done

  if [[ $_total -eq 0 ]]; then
    echo "no frontmattered files found across the kingdom"
    return 0
  fi

  printf '\033[1m── kingdom atlas (%d files) ──\033[0m\n\n' "$_total"

  local _active_order=(ready draft filed dispatched in-progress design awaiting-koad queued directional visionaries)
  local _done_order=(landed shipped complete completed delivered closed merged archived canonical resolved)
  local _active_total=0 _done_total=0

  # Print active statuses
  for _s in "${_active_order[@]}"; do
    [[ -n "${_by_status[$_s]:-}" ]] || continue
    printf '\033[1;32m▸ %s\033[0m\n' "$_s"
    echo -n "${_by_status[$_s]}"
    _active_total=$((_active_total + $(echo "${_by_status[$_s]}" | wc -l)))
  done

  # Print done statuses
  for _s in "${_done_order[@]}"; do
    [[ -n "${_by_status[$_s]:-}" ]] || continue
    printf '\033[1;90m▾ %s\033[0m\n' "$_s"
    echo -n "${_by_status[$_s]}"
    _done_total=$((_done_total + $(echo "${_by_status[$_s]}" | wc -l)))
  done

  # Remaining statuses
  local _remaining=""
  for _s in "${!_by_status[@]}"; do
    local _known=0
    for _k in "${_active_order[@]}" "${_done_order[@]}"; do
      [[ "$_s" == "$_k" ]] && _known=1 && break
    done
    [[ $_known -eq 0 ]] && _remaining="$_remaining${_by_status[$_s]}"
  done
  if [[ -n "$_remaining" ]]; then
    printf '\033[1;33m▸ other\033[0m\n'
    echo -n "$_remaining"
  fi

  local _other_total=$(( _total - _active_total - _done_total ))
  echo
  printf '  \033[1m%d active, %d done, %d other\033[0m\n' "$_active_total" "$_done_total" "$_other_total"
  return 0
}

# MODE: --echo <topic>
_mode_echo() {
  local _topic="${MODE_ARG,,}"  # lowercase
  [[ -z "$_topic" ]] && { echo "error: --echo requires a topic" >&2; return 1; }

  printf '\033[1m── echo: %s ──\033[0m\n\n' "$MODE_ARG"
  local _found=0

  local -a _entities_arr=()
  if [[ -n "$ONLY_ENTITY" ]]; then
    _entities_arr=("$ONLY_ENTITY")
  else
    mapfile -t _entities_arr < <(_list_entities | sort)
  fi

  for _name in "${_entities_arr[@]}"; do
    local _dir="$HOME/.$_name"
    local _entity_found=0
    for _rel in "${_op_dirs[@]}"; do
      local _path="$_dir/$_rel"
      [[ -d "$_path" ]] || continue
      while IFS= read -r _md; do
        [[ -f "$_md" ]] || continue
        local _title _desc _tags _basename
        _title="$(_fm_val "$_md" title)"
        _basename="$(basename "$_md" .md)"
        _desc="$(_fm_val "$_md" description)"
        _tags="$(_fm_val "$_md" tags)"

        local _match=0
        # Check each word of the topic against title + description + tags + filename
        for _word in $_topic; do
          local _all_words=1
          for _token in $_word; do
            local _haystack="${_title,,} ${_desc,,} ${_tags,,} ${_basename,,}"
            [[ "$_haystack" == *"${_token,,}"* ]] || { _all_words=0; break; }
          done
          [[ $_all_words -eq 1 ]] && _match=1 && break
        done

        if [[ $_match -eq 1 ]]; then
          if [[ $_entity_found -eq 0 ]]; then
            printf '\033[1m── %s ──\033[0m\n' "$_name"
            _entity_found=1
          fi
          _display_md "$_md"
          echo
          _found=1
        fi
        [[ $LIMIT -gt 0 ]] && [[ $_found -ge $LIMIT ]] && break 3
      done < <(find "$_path" -name '*.md' $(_exclude_find "$_path") 2>/dev/null)
    done
    [[ $_entity_found -eq 1 ]] && echo
  done

  [[ $_found -eq 0 ]] && echo "no echoes for '$MODE_ARG' across the kingdom"
  return 0
}

# --- Mode dispatch ---
# If --from db mode, try DB first; fall back to standard search
if [[ "$FROM_MODE" == "db" ]] && [[ "$MODE" == "search" ]]; then
  if _mode_db_search; then
    exit 0
  fi
  # Fall through to filesystem search
fi

case "$MODE" in
  search)  ;;  # handled below
  related) _mode_related "$MODE_ARG"; exit 0 ;;
  stale)   _mode_stale; exit 0 ;;
  atlas)   _mode_atlas; exit 0 ;;
  echo)    _mode_echo; exit 0 ;;
  *)       echo "unknown mode: $MODE" >&2; exit 1 ;;
esac

# --- Main search entry point ---
_total_found=0

if [[ -n "$ONLY_ENTITY" ]]; then
  _dir="$HOME/.$ONLY_ENTITY"
  if [[ ! -d "$_dir" ]]; then
    echo "error: entity dir not found: $_dir" >&2
    exit 1
  fi
  if ! _scope_allows "$_dir"; then
    echo "error: entity is outside search scope: $ONLY_ENTITY" >&2
    exit 1
  fi
  _search_entity "$ONLY_ENTITY" "$_dir" && _total_found=1
else
  while IFS= read -r _name; do
    _search_entity "$_name" "$HOME/.$_name" && _total_found=1
  done < <(_list_entities | sort)
fi

[[ -z "$ONLY_ENTITY" ]] && { _search_framework && _total_found=1; }

if [[ $_total_found -eq 0 ]]; then
  if [[ -n "$PATTERN" ]]; then
    echo "no matches for '$PATTERN' across the kingdom"
  else
    echo "no files matching where conditions across the kingdom"
  fi
  exit 1
fi
exit 0
