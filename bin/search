#!/usr/bin/env bash
# koad:io unified search — waterfalls through the entire kingdom
# Knows the topology so nobody has to remember where things live.
#
# Modes:
#   search <pattern>                 — text search all entities + framework
#   search --where key=value         — frontmatter query across kingdom
#   search --related <file>          — find everything connected to a file
#   search --stale [days]            — find forgotten work (non-done, untouched)
#   search --atlas                   — kingdom dashboard grouped by status
#   search --echo <topic>            — fuzzy topic match on titles/descriptions
#
# Uses ripgrep (rg) if available, falls back to grep -rn.

set -euo pipefail

PATTERN=""
ONLY_ENTITY=""
ONLY_FRAMEWORK=""
SKIP_COMPLETE=""
MODE="search"  # search | related | stale | atlas | echo
MODE_ARG=""
STALE_DAYS=7
KOAD_IO_DIR="${KOAD_IO_DIR:-$HOME/.koad-io}"
declare -a WHERE_CLAUSES=()

_DONE_STATUSES="landed|shipped|archived|canonical|complete|completed|delivered|closed|merged|resolved"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --entity)         ONLY_ENTITY="$2"; shift 2 ;;
    --framework)      ONLY_FRAMEWORK=1; shift ;;
    --skip-complete)  SKIP_COMPLETE=1; shift ;;
    --where)          WHERE_CLAUSES+=("$2"); shift 2 ;;
    --related)        MODE="related"; MODE_ARG="$2"; shift 2 ;;
    --stale)          MODE="stale"
                      if [[ "${2:-}" =~ ^[0-9]+$ ]]; then
                        STALE_DAYS="$2"; shift 2
                      else
                        shift
                      fi ;;
    --atlas)          MODE="atlas"; shift ;;
    --echo)           MODE="echo"; MODE_ARG="$2"; shift 2 ;;
    --help|-h)
      cat <<'USAGE'
search [<pattern>] [options]

Kingdom-wide search across all operational folders.

Modes:
  search <pattern>              Text search (grep)
  search --where key=value      Frontmatter query (list matching files)
  search <pattern> --where ...  Text search filtered by frontmatter
  search --related <file>       Find everything connected to a file
  search --stale [days]         Find forgotten work (default: 7 days untouched)
  search --atlas                Kingdom dashboard — all work grouped by status
  search --echo <topic>         Fuzzy topic match on titles and descriptions

Where operators:
  key=value     Exact match (case-insensitive)
  key!=value    Not equal
  key~value     Contains / partial match (for arrays, free text)

Multiple --where flags are AND conditions.

Options:
  --entity X         Narrow to one entity
  --framework        Framework dirs only
  --skip-complete    Skip .md files whose frontmatter status is done
                     (landed, shipped, archived, canonical, complete,
                      completed, delivered, closed, merged, resolved)

Examples:
  search "telemetry"                             # text across kingdom
  search --where status=draft                    # all drafts
  search --where "priority=high" --skip-complete # high-pri, still open
  search --related ~/.juno/briefs/daemon-flight-telemetry.md
  search --stale 14                              # untouched for 2 weeks
  search --atlas                                 # the big picture
  search --echo "oauth"                          # anything about oauth
USAGE
      exit 0
      ;;
    -*)  echo "unknown flag: $1" >&2; exit 1 ;;
    *)   PATTERN="$1"; shift ;;
  esac
done

# --- Validate mode ---
if [[ "$MODE" == "search" ]] && [[ -z "$PATTERN" ]] && [[ ${#WHERE_CLAUSES[@]} -eq 0 ]]; then
  echo "usage: search [<pattern>] [--where key=value] [--related <file>] [--stale [days]] [--atlas] [--echo <topic>]" >&2
  exit 1
fi

# --- Search engine ---
_NOISE_DIRS=(.git node_modules .npm .meteor packages .claude .opencode .local .trash trash .archive archive builds isopacks dist id .vscode-oss)
_NOISE_FILES=(.context '*.asc' '*.gpg' '*.pub' '*.pem')

if command -v rg &>/dev/null; then
  _search_raw() {
    local _args=(--no-heading --line-number --color=always)
    for _d in "${_NOISE_DIRS[@]}"; do _args+=(--glob "!$_d"); done
    for _f in "${_NOISE_FILES[@]}"; do _args+=(--glob "!$_f"); done
    rg "${_args[@]}" "$PATTERN" "$@" 2>/dev/null || true
  }
else
  _search_raw() {
    local _args=(-rn --color=always)
    for _d in "${_NOISE_DIRS[@]}"; do _args+=(--exclude-dir="$_d"); done
    for _f in "${_NOISE_FILES[@]}"; do _args+=(--exclude="$_f"); done
    grep "${_args[@]}" "$PATTERN" "$@" 2>/dev/null || true
  }
fi

# --- Frontmatter reader ---
_read_frontmatter() {
  local _file="$1"
  [[ -f "$_file" ]] || return 1
  awk '
    NR==1 && /^---/ { in_fm=1; next }
    in_fm && /^---/ { exit }
    in_fm { print }
  ' "$_file" 2>/dev/null
}

# --- Get a single frontmatter value ---
_fm_val() {
  local _file="$1" _key="$2"
  _read_frontmatter "$_file" | { grep -iE "^${_key}:" || true; } | head -1 | sed "s/^[^:]*:\s*//" | sed 's/^"\(.*\)"$/\1/'
}

# --- Where clause evaluator ---
_matches_where() {
  local _file="$1"
  [[ "$_file" == *.md ]] || return 1
  [[ -f "$_file" ]] || return 1

  local _fm
  _fm="$(_read_frontmatter "$_file")"
  [[ -n "$_fm" ]] || return 1

  for _clause in "${WHERE_CLAUSES[@]}"; do
    local _key _op _val

    if [[ "$_clause" == *"!="* ]]; then
      _op="!="
      _key="${_clause%%!=*}"
      _val="${_clause#*!=}"
    elif [[ "$_clause" == *"~"* ]]; then
      _op="~"
      _key="${_clause%%~*}"
      _val="${_clause#*~}"
    elif [[ "$_clause" == *"="* ]]; then
      _op="="
      _key="${_clause%%=*}"
      _val="${_clause#*=}"
    else
      return 1
    fi

    local _fm_val
    _fm_val="$(echo "$_fm" | grep -iE "^${_key}:" | head -1 | sed "s/^[^:]*:\s*//")"

    case "$_op" in
      "=")  [[ "${_fm_val,,}" == "${_val,,}" ]] || return 1 ;;
      "!=") [[ -n "$_fm_val" ]] && [[ "${_fm_val,,}" == "${_val,,}" ]] && return 1 ;;
      "~")  [[ "${_fm_val,,}" == *"${_val,,}"* ]] || return 1 ;;
    esac
  done
  return 0
}

# --- Completion filter ---
_is_complete() {
  local _file="$1"
  [[ "$_file" == *.md ]] || return 1
  [[ -f "$_file" ]] || return 1
  head -15 "$_file" 2>/dev/null | grep -qiE "^status:\s*($_DONE_STATUSES)" && return 0
  return 1
}

# --- File filter ---
_should_skip_file() {
  local _file="$1"
  [[ -n "$SKIP_COMPLETE" ]] && _is_complete "$_file" && return 0
  [[ ${#WHERE_CLAUSES[@]} -gt 0 ]] && ! _matches_where "$_file" && return 0
  return 1
}

# --- Filter result lines ---
_filter_results() {
  local _result="$1"
  [[ -n "$_result" ]] || return 0

  if [[ -z "$SKIP_COMPLETE" ]] && [[ ${#WHERE_CLAUSES[@]} -eq 0 ]]; then
    echo "$_result"
    return 0
  fi

  local _filtered="" _prev_file="" _prev_skip=""
  while IFS= read -r _line; do
    local _clean
    _clean="$(echo "$_line" | sed 's/\x1b\[[0-9;]*m//g')"
    local _file
    _file="$(echo "$_clean" | cut -d: -f1)"

    if [[ "$_file" != "$_prev_file" ]]; then
      _prev_file="$_file"
      if _should_skip_file "$_file"; then _prev_skip=1; else _prev_skip=0; fi
    fi

    [[ "$_prev_skip" -eq 0 ]] && _filtered+="$_line"$'\n'
  done <<< "$_result"

  _filtered="${_filtered%$'\n'}"
  [[ -n "$_filtered" ]] && echo "$_filtered"
}

_search() {
  local _result
  _result="$(_search_raw "$@")"
  _filter_results "$_result"
}

# --- Display a file entry with frontmatter metadata ---
_display_file() {
  local _file="$1"
  local _title _status _priority
  _title="$(_fm_val "$_file" title)"
  _status="$(_fm_val "$_file" status)"
  _priority="$(_fm_val "$_file" priority)"

  local _display
  _display="$(printf '\033[0;36m%s\033[0m' "$_file")"
  [[ -n "$_title" ]] && _display+="  $(printf '\033[0;33m%s\033[0m' "$_title")"
  [[ -n "$_status" ]] && _display+="  $(printf '\033[0;35m[%s]\033[0m' "$_status")"
  [[ -n "$_priority" ]] && _display+="  $(printf '\033[0;31m(%s)\033[0m' "$_priority")"
  echo "$_display"
}

# --- Walk .md files in a dir, applying noise exclusions ---
_walk_md() {
  local _dir="$1"
  [[ -d "$_dir" ]] || return
  local _exclude_args=()
  for _d in "${_NOISE_DIRS[@]}"; do _exclude_args+=(-not -path "*/$_d/*"); done
  find "$_dir" -type f -name "*.md" "${_exclude_args[@]}" 2>/dev/null | sort
}

# --- Frontmatter-only query ---
_query_files_in_dir() {
  local _dir="$1"
  while IFS= read -r _file; do
    [[ -f "$_file" ]] || continue
    _should_skip_file "$_file" && continue
    _display_file "$_file"
  done < <(_walk_md "$_dir")
}

# --- Operational folders ---
_op_dirs=(
  briefs memories tickler horizons trust/bonds commands hooks skills
  destinations control ARCHITECTURE PROJECTS assessments reports
  heals reviews specs posts queues docs documentation
)

_op_files=(ENTITY.md PRIMER.md OPERATIONS.md GOVERNANCE.md TEAM_STRUCTURE.md BUSINESS_MODEL.md)

# --- Search/query one entity ---
_search_entity() {
  local _name="$1"
  local _dir="$2"
  local _entity_found=0

  if [[ -n "$PATTERN" ]]; then
    for _rel in "${_op_dirs[@]}"; do
      local _path="$_dir/$_rel"
      [[ -d "$_path" ]] || continue
      local _result
      _result="$(_search "$_path")"
      if [[ -n "$_result" ]]; then
        [[ $_entity_found -eq 0 ]] && printf '\033[1m── %s ──\033[0m\n' "$_name"
        _entity_found=1
        printf '\033[1;34m%s/\033[0m\n' "$_rel"
        echo "$_result"
        echo
      fi
    done
    for _file in "${_op_files[@]}"; do
      local _path="$_dir/$_file"
      [[ -f "$_path" ]] || continue
      local _result
      _result="$(_search "$_path")"
      if [[ -n "$_result" ]]; then
        [[ $_entity_found -eq 0 ]] && printf '\033[1m── %s ──\033[0m\n' "$_name"
        _entity_found=1
        echo "$_result"
        echo
      fi
    done
  else
    for _rel in "${_op_dirs[@]}"; do
      local _path="$_dir/$_rel"
      [[ -d "$_path" ]] || continue
      local _result
      _result="$(_query_files_in_dir "$_path")"
      if [[ -n "$_result" ]]; then
        [[ $_entity_found -eq 0 ]] && printf '\033[1m── %s ──\033[0m\n' "$_name"
        _entity_found=1
        printf '\033[1;34m%s/\033[0m\n' "$_rel"
        echo "$_result"
        echo
      fi
    done
    for _file in "${_op_files[@]}"; do
      local _path="$_dir/$_file"
      [[ -f "$_path" ]] || continue
      _should_skip_file "$_path" && continue
      if _matches_where "$_path" 2>/dev/null; then
        [[ $_entity_found -eq 0 ]] && printf '\033[1m── %s ──\033[0m\n' "$_name"
        _entity_found=1
        printf '\033[0;36m%s\033[0m\n' "$_path"
        echo
      fi
    done
  fi
  return $(( _entity_found == 0 ))
}

# --- Search framework ---
_search_framework() {
  local _fw_dirs=(commands harness skeletons helpers bin)
  local _fw_found=0

  for _rel in "${_fw_dirs[@]}"; do
    local _dir="$KOAD_IO_DIR/$_rel"
    [[ -d "$_dir" ]] || continue
    local _result
    if [[ -n "$PATTERN" ]]; then
      _result="$(_search "$_dir")"
    else
      _result="$(_query_files_in_dir "$_dir")"
    fi
    if [[ -n "$_result" ]]; then
      [[ $_fw_found -eq 0 ]] && printf '\033[1m── koad-io (framework) ──\033[0m\n'
      _fw_found=1
      printf '\033[1;34m%s/\033[0m\n' "$_rel"
      echo "$_result"
      echo
    fi
  done

  if [[ -n "$PATTERN" ]]; then
    for _file in KOAD_IO.md; do
      local _path="$KOAD_IO_DIR/$_file"
      [[ -f "$_path" ]] || continue
      local _result
      _result="$(_search "$_path")"
      if [[ -n "$_result" ]]; then
        [[ $_fw_found -eq 0 ]] && printf '\033[1m── koad-io (framework) ──\033[0m\n'
        _fw_found=1
        echo "$_result"
        echo
      fi
    done
  fi
}

# --- Discover entities ---
_list_entities() {
  for _launcher in "$KOAD_IO_DIR"/bin/*; do
    [[ -f "$_launcher" ]] || continue
    local _name
    _name="$(basename "$_launcher")"
    [[ "$_name" == koad-io ]] && continue
    [[ "$_name" == opencode ]] && continue
    [[ "$_name" == search ]] && continue
    [[ "$_name" == entity ]] && continue
    [[ "$_name" =~ ^\. ]] && continue
    [[ "$_name" =~ \.md$ ]] && continue
    [[ "$_name" == "playwright-cli" ]] && continue
    local _dir="$HOME/.$_name"
    [[ -d "$_dir" ]] || continue
    echo "$_name"
  done
}

# ============================================================================
# MODE: --related <file>
# Find everything connected to a file via its frontmatter references.
# ============================================================================
_mode_related() {
  local _file="$1"
  if [[ ! -f "$_file" ]]; then
    echo "error: file not found: $_file" >&2
    exit 1
  fi

  printf '\033[1m── related to: %s ──\033[0m\n\n' "$(basename "$_file")"

  local _fm
  _fm="$(_read_frontmatter "$_file")"

  # Collect search terms from frontmatter relationships
  local -a _terms=()

  # Multi-line YAML list parser: extract items from relates-to, refs, etc.
  # Handles both inline [a, b] and block list (- item) forms.
  _extract_list() {
    local _key="$1"
    local _line
    _line="$(echo "$_fm" | { grep -iE "^${_key}:" || true; } | head -1)"
    [[ -n "$_line" ]] || return 0

    local _inline
    _inline="$(echo "$_line" | sed "s/^[^:]*:\s*//")"

    if [[ "$_inline" == "["*"]" ]]; then
      # Inline array: [a, b, c]
      echo "$_inline" | tr -d '[]' | tr ',' '\n'
    elif [[ -z "$_inline" ]] || [[ "$_inline" =~ ^[[:space:]]*$ ]]; then
      # Block list: lines starting with "  - "
      echo "$_fm" | awk -v key="$_key" '
        BEGIN { found=0; IGNORECASE=1 }
        $0 ~ "^"key":" { found=1; next }
        found && /^[[:space:]]*-/ { sub(/^[[:space:]]*-[[:space:]]*/, ""); print; next }
        found && /^[a-zA-Z]/ { exit }
      '
    else
      echo "$_inline"
    fi
  }

  # relates-to / related / see-also / depends-on
  for _key in relates-to related see-also depends-on refs references; do
    while IFS= read -r _ref; do
      _ref="$(echo "$_ref" | sed 's/[[:space:]]*(.*//' | sed 's/^"//' | sed 's/"$//' | xargs)"
      [[ -n "$_ref" ]] && _terms+=("$_ref")
    done < <(_extract_list "$_key")
  done

  # entities field
  while IFS= read -r _ent; do
    _ent="$(echo "$_ent" | xargs)"
    [[ -n "$_ent" ]] && _terms+=("$_ent")
  done < <(_extract_list "entities")

  # title
  local _title
  _title="$(_fm_val "$_file" title)"
  [[ -n "$_title" ]] && _terms+=("$_title")

  # filename stem
  local _stem
  _stem="$(basename "$_file" .md)"
  _terms+=("$_stem")

  # issues field
  while IFS= read -r _iss; do
    _iss="$(echo "$_iss" | xargs)"
    [[ -n "$_iss" ]] && _terms+=("$_iss")
  done < <(_extract_list "issues")

  if [[ ${#_terms[@]} -eq 0 ]]; then
    echo "no frontmatter references found to follow"
    return
  fi

  # Deduplicate terms
  local -A _seen=()
  local -a _unique=()
  for _t in "${_terms[@]}"; do
    [[ -z "$_t" ]] && continue
    [[ -n "${_seen[$_t]:-}" ]] && continue
    _seen["$_t"]=1
    _unique+=("$_t")
  done

  printf '\033[0;90mSearching for connections: %s\033[0m\n\n' "${_unique[*]}"

  # Build a combined regex from all terms
  local _combined=""
  for _t in "${_unique[@]}"; do
    local _escaped
    _escaped="$(printf '%s' "$_t" | sed 's/[[\.*^$()+?{|]/\\&/g')"
    if [[ -z "$_combined" ]]; then
      _combined="$_escaped"
    else
      _combined="$_combined|$_escaped"
    fi
  done

  PATTERN="$_combined"

  # Run standard entity search, excluding the source file
  local _src_clean
  _src_clean="$(realpath "$_file" 2>/dev/null || echo "$_file")"

  local -a _entities_arr=()
  if [[ -n "$ONLY_ENTITY" ]]; then
    _entities_arr=("$ONLY_ENTITY")
  else
    mapfile -t _entities_arr < <(_list_entities | sort)
  fi

  for _name in "${_entities_arr[@]}"; do
    # Capture output directly
    local _result
    _result="$(_search_entity "$_name" "$HOME/.$_name")" || true
    if [[ -n "$_result" ]]; then
      echo "$_result" | { grep -v "$_src_clean" || true; }
    fi
  done

  _search_framework 2>/dev/null || true
}

# ============================================================================
# MODE: --stale [days]
# Find files with non-done status that haven't been modified in N days.
# ============================================================================
_mode_stale() {
  local _days="$STALE_DAYS"
  local _cutoff
  _cutoff="$(date -d "$_days days ago" +%s 2>/dev/null || date -v-"${_days}"d +%s 2>/dev/null)"

  printf '\033[1m── stale work (untouched > %s days, not done) ──\033[0m\n\n' "$_days"

  local _found=0
  local -a _entities_arr=()
  if [[ -n "$ONLY_ENTITY" ]]; then
    _entities_arr=("$ONLY_ENTITY")
  else
    mapfile -t _entities_arr < <(_list_entities | sort)
  fi

  for _name in "${_entities_arr[@]}"; do
    [[ -z "$_name" ]] && continue
    local _dir="$HOME/.$_name"
    local _entity_found=0

    for _rel in "${_op_dirs[@]}"; do
      local _path="$_dir/$_rel"
      [[ -d "$_path" ]] || continue

      local -a _files_arr=()
      mapfile -t _files_arr < <(_walk_md "$_path")

      for _file in "${_files_arr[@]}"; do
        [[ -f "$_file" ]] || continue

        _is_complete "$_file" && continue

        local _status
        _status="$(_fm_val "$_file" status)"
        [[ -n "$_status" ]] || continue

        local _mtime
        _mtime="$(stat -c %Y "$_file" 2>/dev/null || stat -f %m "$_file" 2>/dev/null)"
        [[ -n "$_mtime" ]] || continue
        [[ "$_mtime" -lt "$_cutoff" ]] || continue

        local _age=$(( ( $(date +%s) - _mtime ) / 86400 ))

        if [[ $_entity_found -eq 0 ]]; then
          printf '\033[1m── %s ──\033[0m\n' "$_name"
          _entity_found=1
          _found=1
        fi

        printf '\033[0;36m%s\033[0m' "$_file"
        printf '  \033[0;35m[%s]\033[0m' "$_status"
        printf '  \033[0;31m%sd untouched\033[0m\n' "$_age"
      done
    done
  done

  [[ $_found -eq 0 ]] && echo "nothing stale — all active work is fresh"
}

# ============================================================================
# MODE: --atlas
# Kingdom dashboard — all frontmattered .md files grouped by status.
# ============================================================================
_mode_atlas() {
  printf '\033[1m── kingdom atlas ──\033[0m\n\n'

  local -A _by_status=()
  local -A _counts=()
  local _total=0

  local -a _entities_arr=()
  if [[ -n "$ONLY_ENTITY" ]]; then
    _entities_arr=("$ONLY_ENTITY")
  else
    mapfile -t _entities_arr < <(_list_entities | sort)
  fi

  for _name in "${_entities_arr[@]}"; do
    [[ -z "$_name" ]] && continue
    local _dir="$HOME/.$_name"

    for _rel in "${_op_dirs[@]}"; do
      local _path="$_dir/$_rel"
      [[ -d "$_path" ]] || continue

      local -a _files_arr=()
      mapfile -t _files_arr < <(_walk_md "$_path")

      for _file in "${_files_arr[@]}"; do
        [[ -f "$_file" ]] || continue

        local _status
        _status="$(_fm_val "$_file" status)"
        [[ -n "$_status" ]] || continue

        local _norm
        _norm="$(echo "$_status" | awk '{print tolower($1)}' | tr -d '—-')"
        [[ -n "$_norm" ]] || continue

        local _title
        _title="$(_fm_val "$_file" title)"
        local _entry
        _entry="$(printf '  \033[0;36m%s\033[0m  \033[0;33m%s\033[0m  \033[0;90m%s\033[0m' "$_name" "${_title:-$(basename "$_file")}" "$_rel")"

        _by_status["$_norm"]+="$_entry"$'\n'
        _counts["$_norm"]=$(( ${_counts["$_norm"]:-0} + 1 ))
        _total=$((_total + 1))
      done
    done
  done

  if [[ $_total -eq 0 ]]; then
    echo "no frontmattered files found across the kingdom"
    return
  fi

  # Display order: active statuses first, then done statuses
  local _active_order=(ready draft filed dispatched in-progress design awaiting-koad queued directional visionaries)
  local _done_order=(landed shipped complete completed delivered closed merged archived canonical resolved)

  # Print active work
  printf '\033[1;32m▸ ACTIVE WORK\033[0m\n'
  for _s in "${_active_order[@]}"; do
    [[ -n "${_by_status[$_s]:-}" ]] || continue
    printf '\n\033[1;33m  %s\033[0m \033[0;90m(%d)\033[0m\n' "$_s" "${_counts[$_s]}"
    echo -n "${_by_status[$_s]}"
    unset "_by_status[$_s]"
  done

  # Print done work
  printf '\n\033[1;34m▸ COMPLETED\033[0m\n'
  for _s in "${_done_order[@]}"; do
    [[ -n "${_by_status[$_s]:-}" ]] || continue
    printf '\n\033[0;34m  %s\033[0m \033[0;90m(%d)\033[0m\n' "$_s" "${_counts[$_s]}"
    echo -n "${_by_status[$_s]}"
    unset "_by_status[$_s]"
  done

  # Print any remaining statuses not in either list
  local _remaining=""
  for _s in "${!_by_status[@]}"; do
    _remaining+="$(printf '\n\033[0;90m  %s\033[0m \033[0;90m(%d)\033[0m\n' "$_s" "${_counts[$_s]}")"
    _remaining+="${_by_status[$_s]}"
  done
  if [[ -n "$_remaining" ]]; then
    printf '\n\033[1;90m▸ OTHER\033[0m\n'
    echo -n "$_remaining"
  fi

  # Summary
  local _active_total=0 _done_total=0
  for _s in ready draft filed dispatched in-progress design awaiting-koad queued directional visionaries; do
    _active_total=$(( _active_total + ${_counts[$_s]:-0} ))
  done
  for _s in landed shipped complete completed delivered closed merged archived canonical resolved; do
    _done_total=$(( _done_total + ${_counts[$_s]:-0} ))
  done
  local _other_total=$(( _total - _active_total - _done_total ))

  printf '\n\033[1m── summary ──\033[0m\n'
  printf '  active: %d  |  completed: %d  |  other: %d  |  total: %d\n' "$_active_total" "$_done_total" "$_other_total" "$_total"
}

# ============================================================================
# MODE: --echo <topic>
# Fuzzy topic match on titles and descriptions in frontmatter.
# ============================================================================
_mode_echo() {
  local _topic="${MODE_ARG,,}"  # lowercase

  printf '\033[1m── echo: %s ──\033[0m\n\n' "$MODE_ARG"

  local _found=0
  local -a _entities_arr=()
  if [[ -n "$ONLY_ENTITY" ]]; then
    _entities_arr=("$ONLY_ENTITY")
  else
    mapfile -t _entities_arr < <(_list_entities | sort)
  fi

  for _name in "${_entities_arr[@]}"; do
    [[ -z "$_name" ]] && continue
    local _dir="$HOME/.$_name"
    local _entity_found=0

    for _rel in "${_op_dirs[@]}"; do
      local _path="$_dir/$_rel"
      [[ -d "$_path" ]] || continue

      local -a _files_arr=()
      mapfile -t _files_arr < <(_walk_md "$_path")

      for _file in "${_files_arr[@]}"; do
        [[ -f "$_file" ]] || continue

        local _title _desc _tags _basename
        _title="$(_fm_val "$_file" title)"
        _desc="$(_fm_val "$_file" description)"
        _tags="$(_fm_val "$_file" tags)"
        _basename="$(basename "$_file" .md)"

        local _match=0
        [[ "${_title,,}" == *"$_topic"* ]] && _match=1
        [[ "${_desc,,}" == *"$_topic"* ]] && _match=1
        [[ "${_tags,,}" == *"$_topic"* ]] && _match=1
        [[ "${_basename,,}" == *"$_topic"* ]] && _match=1

        # Split topic into words for partial matching
        if [[ $_match -eq 0 ]]; then
          local _all_words=1
          for _word in $_topic; do
            local _haystack="${_title,,} ${_desc,,} ${_tags,,} ${_basename,,}"
            [[ "$_haystack" == *"$_word"* ]] || { _all_words=0; break; }
          done
          [[ $_all_words -eq 1 ]] && _match=1
        fi

        if [[ $_match -eq 1 ]]; then
          [[ -n "$SKIP_COMPLETE" ]] && _is_complete "$_file" && continue

          if [[ $_entity_found -eq 0 ]]; then
            printf '\033[1m── %s ──\033[0m\n' "$_name"
            _entity_found=1
            _found=1
          fi

          _display_file "$_file"
        fi
      done
    done
  done

  [[ $_found -eq 0 ]] && echo "no echoes for '$MODE_ARG' across the kingdom"
}

# ============================================================================
# MAIN
# ============================================================================

case "$MODE" in
  related) _mode_related "$MODE_ARG"; exit 0 ;;
  stale)   _mode_stale; exit 0 ;;
  atlas)   _mode_atlas; exit 0 ;;
  echo)    _mode_echo; exit 0 ;;
esac

# Standard search/where mode
_total_found=0

if [[ -n "$ONLY_FRAMEWORK" ]]; then
  _search_framework
  exit 0
fi

if [[ -n "$ONLY_ENTITY" ]]; then
  _dir="$HOME/.$ONLY_ENTITY"
  if [[ ! -d "$_dir" ]]; then
    echo "error: entity dir not found: $_dir" >&2
    exit 1
  fi
  _search_entity "$ONLY_ENTITY" "$_dir" && _total_found=1
else
  while IFS= read -r _name; do
    _search_entity "$_name" "$HOME/.$_name" && _total_found=1
  done < <(_list_entities | sort)

  _search_framework && _total_found=1
fi

if [[ $_total_found -eq 0 ]]; then
  if [[ -n "$PATTERN" ]]; then
    echo "no matches for '$PATTERN' across the kingdom"
  else
    echo "no files matching where conditions across the kingdom"
  fi
fi

# Self-documenting footer — lists flags on TTY, silent when piped.
# shellcheck source=/dev/null
source "$HOME/.koad-io/helpers/discovery.sh" 2>/dev/null && _koad_io_hint
