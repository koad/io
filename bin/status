#!/usr/bin/env bash
# koad:io status — hit well-known endpoints, report alive/dead.
#
# Usage:
#   koad-io status                  One-shot overview
#   koad-io status --json           Raw JSON
#   koad-io status --quiet          No render; exit 0/1/2 by health
#   koad-io status --timeout=N      Per-probe timeout (default 5s)
#   koad-io status --history [N]    Last N probe records (default 20)
#
# Targets: read from $_INDEX_FILE (JSONL, one {"label":"...","url":"..."} per line).
# Override path with KOAD_IO_STATUS_INDEX.

set -euo pipefail

INDEX_FILE="${KOAD_IO_STATUS_INDEX:-$HOME/.local/share/koad-io/services/index.jsonl}"
if [ ! -f "$INDEX_FILE" ]; then
  cat >&2 <<EOF
status: no service index found at $INDEX_FILE

Create it as a JSONL file with one object per line:

  mkdir -p "$(dirname "$INDEX_FILE")"
  echo '{"label":"my-service","url":"http://1.2.3.4:8080"}' >> "$INDEX_FILE"

Each line needs "label" and "url" fields.
EOF
  exit 69
fi

# Parse targets from index
TARGETS=""
while IFS= read -r line; do
  label=$(echo "$line" | jq -r '.label // empty' 2>/dev/null)
  url=$(echo "$line" | jq -r '.url // empty' 2>/dev/null)
  expected=$(echo "$line" | jq -r '.expected_status // empty' 2>/dev/null)
  [ -n "$label" ] && [ -n "$url" ] && TARGETS="$TARGETS $label=$url=$expected"
done < "$INDEX_FILE"

LOG_FILE="${KOAD_IO_STATUS_LOG:-$HOME/.local/share/koad-io/sensors/status.jsonl}"
TIMEOUT=5
JSON=""
QUIET=""
HISTORY=""
HISTORY_LAST=20

while [ $# -gt 0 ]; do
  case "$1" in
    --json)       JSON=1; shift ;;
    --quiet)      QUIET=1; shift ;;
    --timeout)    TIMEOUT="$2"; shift 2 ;;
    --timeout=*)  TIMEOUT="${1#*=}"; shift ;;
    --history)    HISTORY=1
                  [[ "${2:-}" =~ ^[0-9]+$ ]] && { HISTORY_LAST="$2"; shift; }
                  shift ;;
    -h|--help)    sed -n '3,20p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *)            shift ;;
  esac
done

# Colors
if [ -t 1 ]; then
  R=$'\033[0m'; B=$'\033[1m'; D=$'\033[2m'
  GREEN=$'\033[0;32m'; Y=$'\033[0;33m'; RED=$'\033[0;31m'
else
  R="" B="" D="" GREEN="" Y="" RED=""
fi

mkdir -p "$(dirname "$LOG_FILE")"

# ── history ──
if [ -n "$HISTORY" ]; then
  [ -f "$LOG_FILE" ] || { echo "no probe log at $LOG_FILE" >&2; exit 0; }
  tail -n "$HISTORY_LAST" "$LOG_FILE"
  exit 0
fi

# ── probe one target ──
probe_one() {
  local base="$1" label="$2"
  local url="${base%/}/.well-known/koad-io.json"
  local code body entity ms host_port

  host_port="${base#http://}"
  host_port="${host_port#https://}"
  host_port="${host_port%%/*}"

  ms=$(date +%s%3N 2>/dev/null || echo 0)
  if body=$(curl -s --max-time "$TIMEOUT" -w '\n%{http_code}' "$url" 2>/dev/null); then
    code=$(echo "$body" | tail -1)
    body=$(echo "$body" | sed '$d')
    entity=$(echo "$body" | jq -r '.entity // ""' 2>/dev/null)
  else
    code="000"
    entity=""
  fi
  ms=$(( $(date +%s%3N 2>/dev/null || echo 0) - ms ))
  [ "$ms" -lt 0 ] && ms=0

  if [ "$code" != "000" ]; then
    printf '{"label":"%s","url":"%s","host_port":"%s","status":%s,"ms":%s,"alive":true,"entity":"%s"}' \
      "$label" "$url" "$host_port" "$code" "$ms" "$entity"
  else
    printf '{"label":"%s","url":"%s","host_port":"%s","status":0,"ms":%s,"alive":false,"error":"unreachable"}' \
      "$label" "$url" "$host_port" "$ms"
  fi
}

# ── probe all ──
t_start=$(date +%s%3N 2>/dev/null || echo 0)
parts=""
alive=0 dead=0

for entry in $TARGETS; do
  if [[ "$entry" == *"="*"="* ]]; then
    label="${entry%%=*}"
    url="${entry#*=}"
    expected="${url##*=}"
    url="${url%=*}"
  elif [[ "$entry" == *"="* ]]; then
    label="${entry%%=*}"
    url="${entry#*=}"
    expected=""
  else
    label="$entry"
    url="$entry"
    expected=""
  fi
  fragment=$(probe_one "$url" "$label")
  if [ -n "$expected" ] && echo "$fragment" | grep -q '"alive":true'; then
    actual=$(echo "$fragment" | jq -r '.status' 2>/dev/null)
    if [ "$actual" != "$expected" ]; then
      fragment=$(echo "$fragment" | jq -c ".degraded = true | .expected_status = $expected | .degraded_reason = \"HTTP $actual (expected $expected)\"" 2>/dev/null || echo "$fragment")
    fi
  fi
  parts="${parts}${fragment},"
  if echo "$fragment" | grep -q '"alive":true'; then
    alive=$((alive + 1))
  else
    dead=$((dead + 1))
  fi
done
parts="${parts%,}"

t_end=$(date +%s%3N 2>/dev/null || echo 0)
total_ms=$(( t_end - t_start ))
[ "$total_ms" -lt 0 ] && total_ms=0

ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
rec=$(printf '{"ts":"%s","timeout_s":%s,"total_ms":%s,"alive":%s,"dead":%s,"targets":[%s]}\n' \
  "$ts" "$TIMEOUT" "$total_ms" "$alive" "$dead" "$parts")

# ── log ──
printf '%s\n' "$rec" >> "$LOG_FILE"

# ── json ──
if [ -n "$JSON" ]; then
  printf '%s\n' "$rec"
  exit 0
fi

# ── render ──
printf '%s── koad:io status (%s%sms%s) ──%s\n' "$D" "$B" "$total_ms" "$D" "$R"

echo "$rec" | jq -r '.targets[] | "\(.host_port // .label)|\(.label)|\(if .alive then .status else 0 end)|\(.ms)|\(.alive)|\(if .entity != "" and .entity != .label then .entity else "" end)|\(.error // "unreachable")|\(.degraded // false)|\(.expected_status // "")|\(.degraded_reason // "")"' | while IFS='|' read -r host_port label status ms alive entity err degraded expected degraded_reason; do
  if [ "$alive" = "true" ]; then
    info="$label"
    [ -n "$entity" ] && info="${info} (${entity})"
    if [ "$degraded" = "true" ]; then
      printf '  %s◐%s %s%s%s  %s%s%s  %sHTTP %s (expected %s) %4sms%s\n' \
        "$Y" "$R" "$B" "$host_port" "$R" "$D" "$info" "$R" "$Y" "$status" "$expected" "$ms" "$R"
    else
      printf '  %s●%s %s%s%s  %s%s%s  %sHTTP %s %4sms%s\n' \
        "$GREEN" "$R" "$B" "$host_port" "$R" "$D" "$info" "$R" "$GREEN" "$status" "$ms" "$R"
    fi
  else
    printf '  %s○%s %s%s%s  %s%s%s  %s%s (%sms)%s\n' \
      "$RED" "$R" "$B" "$host_port" "$R" "$D" "$label" "$R" "$RED" "$err" "$ms" "$R"
  fi
done

# ── summary ──
if [ "$dead" -eq 0 ]; then
  printf '  %sall %s alive%s\n' "$GREEN" "$alive" "$R"
elif [ "$alive" -eq 0 ]; then
  printf '  %sall %s dead%s\n' "$RED" "$dead" "$R"
else
  printf '  %s%s alive, %s dead%s\n' "$Y" "$alive" "$dead" "$R"
fi

# ── exit ──
[ -n "$QUIET" ] && { [ "$dead" -eq 0 ] && exit 0; [ "$alive" -eq 0 ] && exit 2; exit 1; }
[ "$dead" -eq 0 ] && exit 0
[ "$alive" -eq 0 ] && exit 2
exit 1
