.env

patches/**
!patches/PRIMER.md

# Flight plans — ephemeral dispatch artifacts (durable record is commit trailer)
flight-plans/

# Claude Code harness artifacts (regenerated per session)
.claude.json
.claude/
mcp-needs-auth-cache.json
archive/sessions/

# Runtime state
var/
tmp/

# npm cache artifacts inside packages
.npm/

# Python bytecode caches
__pycache__/
*.pyc

# Daemon runtime archive — jsonl sweeps of terminal-status records
daemon/archive/

# Sovereign operator identity — its own repo, not part of the framework
# (VESTA-SPEC-174 §2.4: a user who clones koad:io gets structure, not someone's keys)
me/

# Runtime cache (status probes, etc.)
cache/

# Workspace skeletons — separate repo
skeletons/

desktop/
harness/
passenger/
