{
  "name": "@koad-io/node",
  "version": "1.0.0",
  "description": "Core koad object and shared crypto/IPFS dependencies — standalone Node.js module. The Meteor package koad:io-core imports from here; CLI tools and the daemon can too.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.cjs"
    },
    "./deps": {
      "import": "./deps.js",
      "require": "./deps.cjs"
    },
    "./identity": {
      "import": "./identity.js",
      "require": "./identity.cjs"
    },
    "./pgp": {
      "browser": "./pgp.browser.js",
      "import": "./pgp.js",
      "require": "./pgp.cjs"
    },
    "./ceremony": {
      "import": "./ceremony.js"
    },
    "./ceremony-browser": {
      "browser": "./ceremony-browser.js",
      "import": "./ceremony-browser.js"
    },
    "./sigchain": {
      "import": "./sigchain.js",
      "require": "./sigchain.cjs"
    },
    "./identity-submission": {
      "import": "./identity-submission.js",
      "require": "./identity-submission.cjs"
    },
    "./identity-writer": {
      "import": "./identity-writer.js",
      "require": "./identity-writer.cjs"
    },
    "./identity-receiver": {
      "import": "./identity-receiver.js",
      "require": "./identity-receiver.cjs"
    },
    "./auth": {
      "import": "./auth.js",
      "require": "./auth.cjs"
    }
  },
  "main": "./index.cjs",
  "scripts": {
    "build:browser": "browserify -i sodium -s kbpgp ./browser/kbpgp-with-internals.js -o ./browser/kbpgp.bundle.js && npx uglify-js ./browser/kbpgp.bundle.js -o ./browser/kbpgp.bundle.min.js --compress --mangle && echo 'Bundle built. Copy to forge/websites/kingofalldata.com/src/public/ manually or via sync script.'"
  },
  "dependencies": {
    "@ipld/dag-json": "10.2.7",
    "@noble/ed25519": "2.1.0",
    "@scure/bip39": "2.2.0",
    "isomorphic-ws": "^5.0.0",
    "kbpgp": "2.1.17",
    "multiformats": "13.4.2",
    "simpleddp": "^2.2.4",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=18"
  }
}
